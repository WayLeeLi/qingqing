@model Academy.Models.News
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = Model.Title + " | 青青餐廳";
}

@section Styles {
    <link rel="stylesheet" href="~/css/news-detail.css" />
    <style>
        /* 页面级别微调，确保正文可见 */
        .art-body {
            word-wrap: break-word;
            overflow-wrap: break-word;
            line-height: 1.8;
            font-size: 0.95rem;
            color: #3D1A0C;
        }

            .art-body img {
                max-width: 100%;
                height: auto;
                margin: 1rem 0;
                border-radius: 4px;
            }

        .menu-img-block {
            margin-bottom: 2rem;
        }
    </style>
}
<div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-gd"></div>
    <div class="hero-cnt">
        <span class="hero-eye">MENU 2025</span>
        <h1 class="hero-h1">桌菜<em>菜單</em></h1>
        <span class="hero-sub">CHIN CHIN RESTAURANT · SINCE 1977</span>
    </div>
</div>
<!-- 面包屑 -->
<div class="breadcrumb">
    <a href="@Url.Action("Index", "Home")">首頁</a>
    <span class="sep">/</span>
    <a href="@Url.Action("Index", "News")">最新消息</a>
    <span class="sep">/</span>
    <span class="current">@Model.Title</span>
</div>

<div class="page-body">
    <main class="main-content rv">
        <!-- 文章头部元数据 -->
        <div class="art-meta">
            @{
                string categoryName = ViewBag.CategoryName ?? (Model.Category.Name ?? "最新消息");
                string tagClass = "t-blue";
            }
            <span class="art-tag @tagClass">@categoryName</span>
            <span class="art-date">
                更新日期：@(Model.PubDate.HasValue ? Model.PubDate.Value.ToString("yyyy 年 MM 月 dd 日") :
                          (Model.CDate.HasValue ? Model.CDate.Value.ToString("yyyy 年 MM 月 dd 日") : "近期"))
            </span>
        </div>

        <h1 class="art-title">@Model.Title</h1>

        @if (!string.IsNullOrEmpty(Model.Lable))
        {
            <p class="art-sub">@Model.Lable</p>
        }

        <div class="art-body">
            <!-- 代表图片（如果有） -->
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="menu-img-block">
                    <img src="@Model.ImagePath" alt="@Model.Title" style="width:100%;display:block;">
                    <div class="menu-img-caption">▲ @Model.Title</div>
                </div>
            }

            <!-- 核心内容：正文（富文本 HTML） -->
            @Html.Raw(Model.Content)
        </div>

        <!-- 文章底部：返回和分享 -->
        <div class="art-footer">
            <a href="@Url.Action("Index", "News")" class="art-back">← 返回最新消息</a>
     
        </div>
    </main>

    <!-- 侧边栏 -->
    <aside class="sidebar rv" style="transition-delay:.15s;">
        <!-- 联系卡片 -->
        <div class="sidebar-card">
            <div class="sb-head">
                <span class="sb-head-icon">📞</span>
                <span class="sb-head-title">訂位 ・ 洽詢</span>
            </div>
            <div class="sb-body">
                <div class="sb-contact-item">
                    <span class="sb-ci-icon">📍</span>
                    <div>
                        <span class="sb-ci-label">地址</span>
                        <span class="sb-ci-val">
                            @ViewBag.Address<br>
                            @if (!string.IsNullOrEmpty(ViewBag.TrafficInfo))
                            {
                                <small style="font-size:.68rem;"> @Html.Raw(ViewBag.TrafficInfo)</small>
                            }
                        </span>
                    </div>
                </div>
                <div class="sb-contact-item">
                    <span class="sb-ci-icon">📞</span>
                    <div>
                        <span class="sb-ci-label">訂位電話</span>
                        <span class="sb-ci-val">
                            @if (!string.IsNullOrEmpty(ViewBag.Phone))
                            {
                                var phones = ViewBag.Phone.ToString().Split(',');
                                foreach (var phone in phones)
                                {
                                    <a href="tel:@phone.Trim()">@phone.Trim()</a><br />
                                }
                            }
                        </span>
                    </div>
                </div>
                <div class="sb-contact-item">
                    <span class="sb-ci-icon">🕐</span>
                    <div>
                        <span class="sb-ci-label">營業時間</span>
                        <span class="sb-ci-val"> @Html.Raw(ViewBag.BusinessHours)</span>
                    </div>
                </div>
                <div class="sb-contact-item">
                    <span class="sb-ci-icon">📠</span>
                    <div>
                        <span class="sb-ci-label">傳真</span>
                        <span class="sb-ci-val">@ViewBag.Fax</span>
                    </div>
                </div>
                @{
                    string firstPhone = "";
                    if (!string.IsNullOrEmpty(ViewBag.Phone))
                    {
                        string phoneStr = ViewBag.Phone.ToString();
                        int commaIndex = phoneStr.IndexOf(',');
                        if (commaIndex > 0)
                        {
                            firstPhone = phoneStr.Substring(0, commaIndex).Trim();
                        }
                        else
                        {
                            firstPhone = phoneStr.Trim();
                        }
                    }
                }
            </div>
        </div>

        <!-- 相關消息（后台应传递 ViewBag.SidebarNewsList，若无则显示默认） -->
        <!-- 相關消息 -->
        <div class="sidebar-card">
            <div class="sb-head">
                <span class="sb-head-icon">📰</span>
                <span class="sb-head-title">相關消息</span>
            </div>
            <div class="sb-body" style="padding:.6rem .8rem;">
                @{
                    var sidebarNews = ViewBag.SidebarNewsList as List<Academy.ViewModels.SidebarNewsItem>;
                    if (sidebarNews != null && sidebarNews.Any())
                    {
                        foreach (var item in sidebarNews)
                        {
                            <a class="sb-related-item" href="@Url.Action("Detail", "News", new { id = item.ID })">
                                <div class="sb-ri-icon">
                                    @if (!string.IsNullOrEmpty(item.Thumb))
                                    {
                                        <img src="@item.Thumb" alt="@item.Title">
                                    }
                                </div>
                                <div class="sb-ri-content">
                                    <div class="sb-ri-title">@item.Title</div>
                                    <div class="sb-ri-date">@item.Date</div>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <p style="font-size:.7rem; color:var(--ink-light); text-align:center;">暫無相關消息</p>
                    }
                }
            </div>
        </div>
    </aside>
</div>

@section Scripts {
    <script>
        // 复制链接功能
        window.copyUrl = function () {
            navigator.clipboard.writeText(location.href);
            alert('已複製連結');
        };

        // 滚动显示返回顶部按钮（如果布局中没有则本页不处理）
        const btt = document.getElementById('btt');
        if (btt) {
            window.addEventListener('scroll', () => {
                btt.classList.toggle('vis', window.scrollY > 200);
            });
        }

        // 滚动动画 (rv 类)
        const ro = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in');
                    ro.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.rv').forEach(el => ro.observe(el));
    </script>
}