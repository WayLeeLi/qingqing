@model Academy.ViewModels.NewsListViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "最新消息 - 青青餐廳";
}

@section Styles {
    <link rel="stylesheet" href="~/css/news.css" />
}

<!-- Hero 區塊 -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-gd"></div>
    <div class="hero-cnt">
        <div class="hero-eye">LATEST NEWS</div>
        <h1 class="hero-h1">最新<em>消息</em></h1>
        <p class="hero-sub">News · Events · Announcements</p>
    </div>
</section>

<div class="wrap">
    <!-- 重點公告橫幅（静态，可按需保留） -->
    <div class="banner rv">
        <div class="bn-ico">📢</div>
        <div>
            <div class="bn-ttl">2025 年節訂位公告</div>
            <div class="bn-txt">除夕、初二「中午」已客滿，恕不接受訂位，敬請見諒！<strong>初一全日公休。</strong><br>年節晚餐場次名額有限，歡迎提早致電：<strong>(02) 2269-1127 ／ (02) 2269-6430</strong></div>
        </div>
    </div>

    <!-- 標題與篩選 -->
    <div class="sec-hd rv" style="transition-delay:.1s">
        <div><p class="s-lbl">LATEST NEWS</p><h2 class="s-ttl">最新消息</h2></div>
        <div class="cnt-badge">共 <strong>@Model.TotalCount</strong> 則消息</div>
    </div>

    <!-- 分類篩選按鈕（动态生成） -->
    <div class="filters rv" style="transition-delay:.15s">
        <button class="ftab on" onclick="ft(this,'all')">全部</button>
        @if (Model.Categories != null)
        {
            foreach (var cat in Model.Categories)
            {
                <button class="ftab" onclick="ft(this,'@cat.Tag')">@cat.Name</button>
            }
        }
    </div>

    <!-- 新聞列表 -->
    <div class="nlist" id="nlist">
        @if (Model.NewsList != null && Model.NewsList.Any())
        {
            int delay = 0;
            foreach (var news in Model.NewsList)
            {
                <article class="ncard rv" style="transition-delay:@(delay.ToString("0.00"))s" data-tag="@news.CategoryName">
                    <div class="nd-col">
                        <div class="nd-box">
                            <span class="nd-mo">@news.PublishDate.ToString("MM")</span>
                            <span class="nd-dy">@news.PublishDate.ToString("dd")</span>
                            <span class="nd-yr">@news.PublishDate.Year</span>
                        </div>
                        <div class="nd-line"></div>
                    </div>
                    <div class="nb-col">
                        <span class="ntag @news.TagColorClass">@news.CategoryName</span>
                        <h3 class="ntitle">@news.Title</h3>
                        <p class="nbody">@news.Summary</p>
                       
                    </div>
                </article>
                //delay += 6;
                //if (delay > 30) delay = 30; // 最大延迟0.30秒
            }
        }
        else
        {
            <div class="ncard rv" style="text-align:center; padding: 60px 20px;">
                <p>目前暫無最新消息，請稍後再訪。</p>
            </div>
        }
    </div>
</div>

<!-- CTA 區塊 -->
<section class="sec-cta">
    <p class="cta-label">RESERVATION</p>
    <h2 class="cta-title">歡迎蒞臨青青餐廳</h2>
    <p class="cta-address">新北市土城區中央路三段6號 ╱ 週一至日 11:00–14:00 ／ 17:00–21:00</p>
    <div class="cta-buttons">
        <a href="tel:0222691127" class="btn-primary">📞 立即訂位</a>
        <a href="@Url.Action("Contact", "Home")" class="btn-secondary">線上預約 →</a>
    </div>
</section>

@section Scripts {
    <script>
        // 漢堡選單 (若 Layout 未提供)
        document.getElementById('ham')?.addEventListener('click', () => {
            document.getElementById('navLinks')?.classList.toggle('open');
        });

        // 回到頂部按鈕
        const btt = document.getElementById('btt');
        window.addEventListener('scroll', () => {
            btt?.classList.toggle('vis', window.scrollY > 200);
        });

        // 滾動淡入動畫
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: .08 });
        document.querySelectorAll('.rv').forEach(el => observer.observe(el));

        // 分類篩選功能（兼容动态生成的标签）
        window.ft = function (btn, tag) {
            document.querySelectorAll('.ftab').forEach(t => t.classList.remove('on'));
            btn.classList.add('on');
            document.querySelectorAll('.ncard').forEach(card => {
                const cardTag = card.getAttribute('data-tag');
                const show = tag === 'all' || cardTag === tag;
                card.style.display = show ? 'flex' : 'none';
                if (show) setTimeout(() => card.classList.add('in'), 30);
                else card.classList.remove('in');
            });
        };
    </script>
}