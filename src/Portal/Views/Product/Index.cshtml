@section Scripts {
    <script>
        // 回到顶部按钮显示/隐藏
        var btt = document.getElementById('btt');
        window.addEventListener('scroll', function () {
            btt.classList.toggle('vis', window.scrollY > 200);
        });

        // tab 高亮联动滚动
        var tabs = document.querySelectorAll('.tab-btn');
        var sects = document.querySelectorAll('.cat-sec');
        function setAct(id) {
            for (var i = 0; i < tabs.length; i++) {
                var t = tabs[i];
                if (t.getAttribute('data-target') === id) {
                    t.classList.add('active');
                } else {
                    t.classList.remove('active');
                }
            }
        }
        var obs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) setAct(entry.target.id);
            });
        }, { rootMargin: '-20% 0px -70% 0px' });
        for (var i = 0; i < sects.length; i++) {
            if (sects[i].style.display !== 'none') obs.observe(sects[i]);
        }

        window.goSec = function (id) {
            var el = document.getElementById(id);
            if (el && el.style.display !== 'none') {
                el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                var btn = document.querySelector('.tab-btn[data-target="' + id + '"]');
                if (btn) {
                    var bar = document.getElementById('tabBar');
                    bar.scrollTo({ left: btn.offsetLeft - bar.offsetWidth / 2 + btn.offsetWidth / 2, behavior: 'smooth' });
                }
            }
        };

        // Lightbox 逻辑
        var lb = document.getElementById('lb');
        var lbImg = document.getElementById('lb-img');
        var lbName = document.getElementById('lb-name');
        window.openLb = function (src, name) {
            lbImg.src = src;
            lbName.textContent = name;
            lb.classList.add('show');
            document.body.style.overflow = 'hidden';
        };
        window.closeLbBtn = function () {
            lb.classList.remove('show');
            document.body.style.overflow = '';
            setTimeout(function () { lbImg.src = ''; }, 300);
        };
        window.closeLb = function (e) {
            if (e.target === lb) closeLbBtn();
        };
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeLbBtn(); });

        setAct('sanpei');
    </script>
}