}

@section Styles {
    <link rel="stylesheet" href="~/css/product.css" />
}


<!-- Hero 區塊 -->
<section class="hero">
    <div class="hero-slash"></div>
    <div class="hero-deco-circle"></div>
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-dish-art">
        <circle cx="100" cy="108" r="82" stroke="rgba(212,168,67,.35)" stroke-width="1.5" />
        <circle cx="100" cy="108" r="74" stroke="rgba(212,168,67,.18)" stroke-width="1" />
        <circle cx="100" cy="108" r="68" fill="rgba(253,248,240,.06)" stroke="rgba(212,168,67,.25)" stroke-width="1" />
        <circle cx="100" cy="108" r="44" fill="rgba(200,16,46,.08)" stroke="rgba(212,168,67,.2)" stroke-width=".8" />
        @for (int i = 0; i < 8; i++)
        {
            var angle = i * 45;
            <ellipse cx="100" cy="72" rx="10" ry="18" fill="rgba(212,168,67,.2)" transform="rotate(@angle 100 108)" />
        }
        <circle cx="100" cy="108" r="14" fill="rgba(212,168,67,.15)" stroke="rgba(212,168,67,.35)" stroke-width=".8" />
        <circle cx="100" cy="108" r="5" fill="rgba(212,168,67,.45)" />
        <line x1="155" y1="15" x2="138" y2="185" stroke="rgba(212,168,67,.55)" stroke-width="2.5" stroke-linecap="round" />
        <line x1="170" y1="18" x2="153" y2="185" stroke="rgba(212,168,67,.4)" stroke-width="2" stroke-linecap="round" />
        <circle cx="62" cy="72" r="3" fill="rgba(200,16,46,.5)" />
        <circle cx="140" cy="148" r="2.5" fill="rgba(200,16,46,.4)" />
        <circle cx="130" cy="70" r="2" fill="rgba(212,168,67,.6)" />
        <circle cx="58" cy="138" r="2" fill="rgba(212,168,67,.5)" />
    </svg>
    <div class="hero-text">
        <div class="hero-badge"><span>SIGNATURE DISHES</span></div>
        <h1 class="hero-title">招牌<em>菜色</em></h1>
        <p class="hero-note">名菜有歷史・好菜唯有創新</p>
        <div class="hero-divider"><span></span><i></i><small>SINCE 1977</small><i></i><span></span></div>
    </div>
</section>

