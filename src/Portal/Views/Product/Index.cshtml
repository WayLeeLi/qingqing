@model List<Academy.ViewModels.DishCategoryViewModel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "招牌菜色 - 青青餐廳";
}

@section Styles {
    <link rel="stylesheet" href="~/css/product.css" />
}

<!-- Hero 區塊（保持不变） -->
<section class="hero">
    <div class="hero-slash"></div>
    <div class="hero-deco-circle"></div>
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-dish-art">
        <!-- ... 您的原 SVG 代码 ... -->
    </svg>
    <div class="hero-text">
        <div class="hero-badge"><span>SIGNATURE DISHES</span></div>
        <h1 class="hero-title">招牌<em>菜色</em></h1>
        <p class="hero-note">名菜有歷史・好菜唯有創新</p>
        <div class="hero-divider"><span></span><i></i><small>SINCE 1977</small><i></i><span></span></div>
    </div>
</section>

<!-- 分類標籤欄（直接使用 Model） -->
<div class="tab-bar" id="tabBar">
    @if (Model != null && Model.Any())
    {
        foreach (var cat in Model)
        {
            <button class="tab-btn" data-target="@cat.DomId" onclick="goSec('@cat.DomId')">
                <span class="ti">
                    <!-- 默认图标，可根据分类名自定义不同 SVG -->
                    <svg viewBox="0 0 40 40" fill="none"><path d="M8 30 Q10 18 20 16 Q30 18 32 30Z" fill="rgba(255,255,255,.9)" /><ellipse cx="20" cy="30" rx="12" ry="2.5" fill="rgba(255,255,255,.5)" /><circle cx="14" cy="22" r="2.5" fill="#F0CC78" /><circle cx="20" cy="20" r="2.5" fill="#F0CC78" /><circle cx="26" cy="22" r="2.5" fill="#F0CC78" /><rect x="18" y="8" width="4" height="8" rx="2" fill="rgba(255,255,255,.8)" /></svg>
                </span>
                @cat.Name
            </button>
        }
    }
</div>

<!-- 引言區 -->
<div class="quote">
    <blockquote>「名菜有歷史，好菜唯有創新。每一道手路菜都是三代家族對台灣辦桌文化的熱愛與堅持。」<cite>─ 阿發師 施建發 · 青青餐廳 SINCE 1977</cite></blockquote>
</div>

<main class="menu-container">
    @if (Model != null && Model.Any())
    {
        foreach (var category in Model)
        {
            <section class="cat-sec" id="@category.DomId">
                <div class="cat-hd">
                    <div class="cat-icon" style="background:linear-gradient(135deg,#7A0E20,#C8102E);">
                        <!-- 分类图标 可复用顶部 SVG 或自定义 -->
                        <svg viewBox="0 0 40 40" fill="none"><path d="M8 30 Q10 18 20 16 Q30 18 32 30Z" fill="rgba(255,255,255,.9)" /><ellipse cx="20" cy="30" rx="12" ry="2.5" fill="rgba(255,255,255,.5)" /><circle cx="14" cy="22" r="2.5" fill="#F0CC78" /><circle cx="20" cy="20" r="2.5" fill="#F0CC78" /><circle cx="26" cy="22" r="2.5" fill="#F0CC78" /><rect x="18" y="8" width="4" height="8" rx="2" fill="rgba(255,255,255,.8)" /></svg>
                    </div>
                    <div>
                        <div class="cat-nm">@category.Name</div>
                        <div class="cat-en">@category.NameEn</div>
                    </div>
                    <div class="cat-ct">共 @category.Dishes.Count 道</div>
                </div>
                <div class="grid-wrap">
                    <div class="dishes-grid">
                        @if (category.Dishes.Any())
                        {
                            foreach (var dish in category.Dishes)
                            {
                                <div class="dish-card" onclick="openLb('@dish.ImageUrl', '@dish.Name', '@dish.Description')">
                                    <div class="dish-photo">
                                        <img class="main-img" src="@dish.ImageUrl" alt="@dish.Name" loading="lazy"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                                        <div class="fb" style="background:linear-gradient(135deg,#7A0E20,#C8102E);">
                                            <div class="fb-ic">
                                                <svg viewBox="0 0 40 40" fill="none"><path d="M8 30 Q10 18 20 16 Q30 18 32 30Z" fill="rgba(255,255,255,.9)" /><ellipse cx="20" cy="30" rx="12" ry="2.5" fill="rgba(255,255,255,.5)" /><circle cx="14" cy="22" r="2.5" fill="#F0CC78" /><circle cx="20" cy="20" r="2.5" fill="#F0CC78" /><circle cx="26" cy="22" r="2.5" fill="#F0CC78" /><rect x="18" y="8" width="4" height="8" rx="2" fill="rgba(255,255,255,.8)" /></svg>
                                            </div>
                                            <div class="fb-ln"></div>
                                            <div class="fb-nm">@dish.Name</div>
                                        </div>
                                        <img class="logo-wm" src="@dish.ThumbUrl" alt="">
                                        <div class="zoom-hint">
                                            <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" /></svg>
                                        </div>
                                    </div>
                                    <div class="dish-label">
                                        <div class="dish-nm">@dish.Name</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="dish-card">
                                <div class="dish-photo">
                                    <div class="fb" style="background:linear-gradient(135deg,#7A0E20,#C8102E);">
                                        <div class="fb-ic"><svg viewBox="0 0 40 40" fill="none"><path d="M8 30 Q10 18 20 16 Q30 18 32 30Z" fill="rgba(255,255,255,.9)" /></svg></div>
                                        <div class="fb-ln"></div>
                                        <div class="fb-nm">即將推出</div>
                                    </div>
                                </div>
                                <div class="dish-label"><div class="dish-nm">敬請期待</div></div>
                            </div>
                        }
                    </div>
                </div>
            </section>
        }
    }
    else
    {
        <p style="text-align:center; padding:80px;">尚無菜色資料，請稍後再訪</p>
    }
</main>

<!-- Lightbox 燈箱 -->
<div id="lb" onclick="closeLb(event)">
    <div id="lb-inner">
        <button id="lb-close" onclick="closeLbBtn()">✕</button>
        <div id="lb-img-wrap">
            <img id="lb-img" src="" alt="">
            <img id="lb-logo" src="" alt="阿發師 logo">
        </div>
        <div id="lb-caption">
            <div id="lb-name"></div>
            <div id="lb-desc"></div>
        </div>
    </div>
</div>

<!-- 預約資訊區 -->
<section class="booking-section">
    <p class="booking-label">RESERVATION</p>
    <h2 class="booking-title">立即預訂，品嚐阿發師手路饗宴</h2>
    <a href="tel:0222691127" class="booking-btn">📞 (02) 2269-1127</a>
    <p class="booking-address">新北市土城區中央路三段6號 ╱ 捷運板南線永寧站4號出口</p>
</section>

<button id="btt" class="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <svg viewBox="0 0 24 24"><path d="M12 4L4 12h5v8h6v-8h5z" /></svg>
</button>

@section Scripts {
    <script>
        // 回到頂部按鈕顯示/隱藏
        const btt = document.getElementById('btt');
        window.addEventListener('scroll', () => {
            btt.classList.toggle('vis', window.scrollY > 200);
        });

        // Tab 高亮 + 滾動聯動
        const tabs = document.querySelectorAll('.tab-btn');
        const sections = document.querySelectorAll('.cat-sec');
        function setActiveTab(id) {
            tabs.forEach(tab => {
                const target = tab.getAttribute('data-target');
                if (target === id) tab.classList.add('active');
                else tab.classList.remove('active');
            });
        }
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) setActiveTab(entry.target.id);
            });
        }, { rootMargin: '-20% 0px -70% 0px' });
        sections.forEach(sec => observer.observe(sec));

        window.goSec = function (id) {
            const targetSec = document.getElementById(id);
            if (targetSec) {
                targetSec.scrollIntoView({ behavior: 'smooth', block: 'start' });
                const activeBtn = document.querySelector(`.tab-btn[data-target="${id}"]`);
                if (activeBtn) {
                    const bar = document.getElementById('tabBar');
                    bar.scrollTo({
                        left: activeBtn.offsetLeft - bar.offsetWidth / 2 + activeBtn.offsetWidth / 2,
                        behavior: 'smooth'
                    });
                }
            }
        };

        // Lightbox 邏輯（支援描述）
        const lb = document.getElementById('lb');
        const lbImg = document.getElementById('lb-img');
        const lbName = document.getElementById('lb-name');
        const lbDesc = document.getElementById('lb-desc');
        window.openLb = function (src, name, desc) {
            lbImg.src = src || '';
            lbName.textContent = name;
            lbDesc.textContent = desc || '';
            lb.classList.add('show');
            document.body.style.overflow = 'hidden';
        };
        window.closeLbBtn = function () {
            lb.classList.remove('show');
            document.body.style.overflow = '';
            setTimeout(() => { lbImg.src = ''; lbDesc.textContent = ''; }, 300);
        };
        window.closeLb = function (e) {
            if (e.target === lb) closeLbBtn();
        };
        document.addEventListener('keydown', e => e.key === 'Escape' && closeLbBtn());

        // 初始高亮第一個分類
        if (sections.length) setActiveTab(sections[0].id);
    </script>
}