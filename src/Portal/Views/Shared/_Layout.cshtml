<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>青青餐廳 | 台菜廚神 SINCE 1977 - @ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;600;700;900&family=Ma+Shan+Zheng&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <script type="text/javascript" src="~/js/site.js"></script>
    <style>
        /* 动态导航栏边框颜色控制 */
        nav.nav-home {
            border-bottom-color: var(--red) !important;
        }

        nav.nav-other {
            border-bottom-color: var(--gold) !important;
        }
        /* 确保 nav 已有的 border-bottom 样式能被覆盖（site.css 中应保持基础样式，不含颜色） */
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ══ NAV ══ -->
    @{
        var controller = ViewContext.RouteData.Values["controller"] as string;
        var action = ViewContext.RouteData.Values["action"] as string;
        var isHomePage = controller == "Home" && action == "Index";
        var navClass = isHomePage ? "nav-home" : "nav-other";
    }
    <nav class="@navClass">
        <div class="nav-logo-wrap">
            <a href="@Url.Action("Index", "Home")" style="display:block;">
                <img src="~/images/web/templatemo_logo.png" alt="青青餐廳" style="height:64px; width:auto; display:block;">
            </a>
        </div>
        <ul class="nav-links" id="navLinks">
            <li><a href="@Url.Action("Index", "About")">關於我們</a></li>
            <li><a href="@Url.Action("Index", "Product")">招牌菜色</a></li>
            <li><a href="@Url.Action("Index", "News")">最新消息</a></li>
            <li><a href="@Url.Action("Index", "Media")">影音專區</a></li>
            <li><a href="@Url.Action("Index", "Home")">服務項目</a></li>
            <li><a href="@Url.Action("Index", "Contact")">聯絡我們</a></li>
            <li><a href="@Url.Action("Index", "Contact")" class="nav-cta">立即訂位</a></li>
        </ul>
        <button class="hamburger" id="hamburger" aria-label="選單">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- ══ FOOTER ══ -->
    <footer>
        <svg width="120" height="20" viewBox="0 0 120 20" style="display:block;margin:0 auto .8rem;" xmlns="http://www.w3.org/2000/svg">
            <line x1="0" y1="10" x2="45" y2="10" stroke="#D4A843" stroke-width=".8" opacity=".4" />
            <polygon points="60,2 67,10 60,18 53,10" fill="none" stroke="#D4A843" stroke-width=".8" opacity=".6" />
            <line x1="75" y1="10" x2="120" y2="10" stroke="#D4A843" stroke-width=".8" opacity=".4" />
        </svg>
        <strong>青青餐廳 Chin Chin Restaurant</strong><br>
        © 2025 All Rights Reserved ╱ SINCE 1977 ╱ 新北市土城區中央路三段6號<br>
        <span style="color:#C8102E; opacity:.6;">怡華股份有限公司</span>
    </footer>

    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>