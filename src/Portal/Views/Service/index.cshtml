@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "服務項目 | 青青餐廳 SINCE 1977";
}

@section Styles {
    <link rel="stylesheet" href="~/css/service.css" />
    <style>
        /* 環境介紹區域樣式 */
        .environment-section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 48px;
            background: var(--paper);
        }
        .environment-header {
            margin-bottom: 40px;
        }
        .environment-header .tag {
            display: inline-block;
            color: var(--gold);
            font-size: 14px;
            letter-spacing: 0.2em;
            margin-bottom: 16px;
        }
        .environment-header h2 {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 16px;
            line-height: 1.2;
        }
        .environment-desc {
            font-size: 1rem;
            color: #666;
            line-height: 1.8;
            margin-top: 8px;
        }
        .environment-desc strong {
            color: var(--red);
            font-size: 1.05rem;
        }
        .environment-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            margin-top: 40px;
        }
        .environment-item {
            position: relative;
            overflow: hidden;
            border-radius: 16px;
            aspect-ratio: 16/9;
            cursor: pointer;
            transition: transform 0.3s ease;
        }
        .environment-item:hover {
            transform: scale(1.02);
        }
        .environment-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .environment-item:hover img {
            transform: scale(1.05);
        }
        .environment-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
            padding: 20px;
            color: #fff;
            font-size: 1rem;
            font-weight: 500;
        }
        @@media (max-width: 768px) {
            .environment-section {
                padding: 40px 20px;
            }
            .environment-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            .environment-header h2 {
                font-size: 1.8rem;
            }
        }
    </style>
}

<!-- ══ PAGE HERO（子页横幅）══ -->
<div class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
        <div class="tag">SERVICE</div>
        <h1>服務項目</h1>
        <div class="page-hero-breadcrumb">
            <a href="@Url.Action("Index", "Home")">首頁</a>
            &nbsp;/&nbsp;服務項目
        </div>
    </div>
    <svg class="hero-deco-line" viewBox="0 0 1440 20" preserveAspectRatio="none">
        <path d="M0,10 Q360,0 720,10 Q1080,20 1440,10 L1440,20 L0,20 Z" fill="var(--paper)" />
    </svg>
</div>

<!-- 簡介條 -->
<div class="intro-strip">
    <p>
        青青餐廳自 1977 年深耕土城，擁有千坪宴席場地、128桌容量，由台灣廚神阿發師親領廚藝團隊，
        承辦各式喜慶宴客，一手包辦婚宴、尾牙、聚餐、外帶年菜，讓每個重要時刻留下難忘滋味。
    </p>
</div>

<!-- 六大服務卡片（從 Model 動態產生） -->
<section class="section-pad" style="background:var(--paper); padding-bottom:3px;">
    <div class="svc-section-header">
        <div class="tag">服務項目</div>
        <h2 class="h2">每個重要時刻<br>交給青青</h2>
        <div class="gold-rule"><span>◆</span></div>
    </div>
</section>

<div class="svc-big-grid">
    @{
        bool hasServices = Model.ServiceList != null && Model.ServiceList.Count > 0;
        if (hasServices)
        {
            foreach (var service in Model.ServiceList)
            {
                <div class="svc-big-card anim">
                    @Html.Raw(service.Content)
                </div>
            }
        }
        else
        {
            <div style="grid-column:1/-1; text-align:center; padding:40px;">暫無服務項目</div>
        }
    }
</div>

<!-- ══ 環境介紹（新增，標題靠左）══ -->
<section class="environment-section">
    <div class="environment-header">
        <div class="tag">ENVIRONMENT</div>
        <h2>環境介紹</h2>
        <div class="environment-desc">
            <strong>千坪宴席場地 · 128桌容量</strong><br>
            小橋流水庭園造景，氣派典雅，適合婚宴喜慶、企業尾牙、家庭聚餐
        </div>
    </div>
    <div class="environment-grid">
        <!-- 第1行第1列 -->
        <div class="environment-item">
            <img src="/images/web/hjjs_1_131.jpg"  onerror="this.src='https://picsum.photos/id/106/800/450'">
            
        </div>
        <!-- 第1行第2列 -->
        <div class="environment-item">
            <img src="/images/web/hjjs_2_96_131.jpg"  onerror="this.src='https://picsum.photos/id/96/800/450'">
            
        </div>
        <!-- 第2行第1列 -->
        <div class="environment-item">
            <img src="/images/web/hjjs_6_95_131.jpg"  onerror="this.src='https://picsum.photos/id/107/800/450'">
            
        </div>
        <!-- 第2行第2列 -->
        <div class="environment-item">
            <img src="/images/web/hjjs_4_98_131.jpg"  onerror="this.src='https://picsum.photos/id/116/800/450'">
            
        </div>
        <!-- 第3行第1列 -->
        <div class="environment-item">
            <img src="/images/web/hjjs_5_99_131.jpg"  onerror="this.src='https://picsum.photos/id/95/800/450'">
            
        </div>
        <!-- 第3行第2列 -->
        <div class="environment-item">
            <img src="/images/web/hjjs_3_97_131.jpg"  onerror="this.src='https://picsum.photos/id/104/800/450'">
        </div>
    </div>
</section>

<!-- ══ FEATURE POINTS ══ -->
<section class="feature-section">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="tag" style="color:var(--gold); --red:var(--gold);">青青優勢</div>
        <h2 class="h2" style="color:#fff;">為何選擇青青餐廳</h2>
    </div>
    <div class="feature-grid">
        <div class="feature-item anim">
            <div class="feature-icon">🏆</div>
            <div class="feature-title">台灣廚神坐鎮</div>
            <p class="feature-desc">主廚阿發師施建發，《飲食男女》廚藝顧問，多項國際中餐大師殊榮，四十年淬鍊的台菜功夫。</p>
        </div>
        <div class="feature-item anim">
            <div class="feature-icon">🏟️</div>
            <div class="feature-title">千坪宴席場地</div>
            <p class="feature-desc">最多可容納 128 桌，小橋流水庭景，三套光音響設備，大型停車場，交通便利永寧站步行可達。</p>
        </div>
        <div class="feature-item anim">
            <div class="feature-icon">⚡</div>
            <div class="feature-title">大量出菜不失水準</div>
            <p class="feature-desc">深耕宴席40年，總舖師功力在於大量快速出菜同時確保溫度與美味，讓每一桌都是精彩表現。</p>
        </div>
        <div class="feature-item anim">
            <div class="feature-icon">🥩</div>
            <div class="feature-title">頂級食材嚴選</div>
            <p class="feature-desc">石碇黑毛豬、每日現進鮮魚、野生海鮮，菜色變化多樣，可依顧客需求彈性調整烹調方式。</p>
        </div>
        <div class="feature-item anim">
            <div class="feature-icon">🚗</div>
            <div class="feature-title">接送專車服務</div>
            <p class="feature-desc">備有專車接送服務，讓賓客無需擔心交通問題，從捷運站到餐廳全程舒適接待。</p>
        </div>
        <div class="feature-item anim">
            <div class="feature-icon">📺</div>
            <div class="feature-title">媒體口碑保證</div>
            <p class="feature-desc">非凡大探索、各大美食節目爭相報導，47年口碑積累，在地最具代表性的台菜宴席餐廳。</p>
        </div>
    </div>
</section>

<!-- 加值服務卡片群（從 Model 動態） -->
<section class="section-pad" style="background:var(--paper); padding-top:2rem;">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="tag">附加服務</div>
        <h2 class="h2">更多貼心選項</h2>
    </div>
    <div class="services-grid">
        @{
            bool hasMoreServices = Model.ServiceMoreList != null && Model.ServiceMoreList.Count > 0;
            if (hasMoreServices)
            {
                foreach (var service in Model.ServiceMoreList)
                {
                    <div class="service-card anim">
                        @Html.Raw(service.Content)
                    </div>
                }
            }
            else
            {
                <div style="grid-column:1/-1; text-align:center; padding:40px;">暫無服務項目</div>
            }
        }
    </div>
</section>

<!-- CTA 區塊 -->
<div class="cta-strip">
    <div class="cta-strip-inner">
        <h2>準備好為您服務</h2>
        <p>歡迎來電或親臨洽談，專人為您量身規劃最完美的宴席方案<br>每日 11:00 — 22:00 全年無休（特殊節日除外）</p>
        
    </div>
</div>

<!-- 聯絡資訊區 -->
<div class="contact-wrap" id="contact">
    <div class="contact-info">
        <div class="tag">聯絡我們</div>
        <h2 class="h2" style="color:#fff; margin-bottom:0;">歡迎蒞臨<br>青青餐廳</h2>
        <div class="contact-items">
            <!-- 地址 -->
            <div class="c-item">
                <div class="c-icon">📍</div>
                <div>
                    <div class="c-label">地址</div>
                    <div class="c-text">
                        @(string.IsNullOrEmpty(ViewBag.Address) ? "新北市土城區中央路三段6號" : ViewBag.Address)
                        <br><small style="opacity:.6">板南線永寧站4號出口，步行約350公尺</small>
                    </div>
                </div>
            </div>

            <!-- 電話（支援多組，以逗號分隔） -->
            <div class="c-item">
                <div class="c-icon">📞</div>
                <div>
                    <div class="c-label">訂位電話</div>
                    <div class="c-text">
                        @if (!string.IsNullOrEmpty(ViewBag.Phone))
                        {
                            var phones = ViewBag.Phone.ToString().Split(new[] { ',', '，', '/' }, StringSplitOptions.RemoveEmptyEntries);
                            foreach (var p in phones)
                            {
                                var cleanPhone = p.Trim().Replace(" ", "").Replace("-", "");
                                <a href="tel:@cleanPhone">@p.Trim()</a><br />
                            }
                        }
                        else
                        {
                            <a href="tel:0222691127">02-2269-1127</a><br />
                            <a href="tel:0222696430">02-2269-6430</a>
                        }
                    </div>
                </div>
            </div>

            <!-- 營業時間（支援 HTML） -->
            <div class="c-item">
                <div class="c-icon">🕐</div>
                <div>
                    <div class="c-label">營業時間</div>
                    <div class="c-text">
                        @if (!string.IsNullOrEmpty(ViewBag.BusinessHours))
                        {
                            @Html.Raw(ViewBag.BusinessHours)
                        }
                        else
                        {
                            <span>每日 11:00 — 22:00</span>
                        }
                    </div>
                </div>
            </div>

            <!-- 電子信箱 -->
            <div class="c-item">
                <div class="c-icon">✉️</div>
                <div>
                    <div class="c-label">電子信箱</div>
                    <div class="c-text">
                        @if (!string.IsNullOrEmpty(ViewBag.Email))
                        {
                            <a href="mailto:@ViewBag.Email">@ViewBag.Email</a>
                        }
                        else
                        {
                            <a href="mailto:service@chinchin.com.tw">service@chinchin.com.tw</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="map-box">
        @if (!string.IsNullOrEmpty(ViewBag.MapUrl))
        {
            <iframe src="@ViewBag.MapUrl" style="border:0;width:100%;height:100%;min-height:420px;display:block;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="青青餐廳地圖位置"></iframe>
        }
        else
        {
            <div class="alert">地圖尚未設定</div>
        }
    </div>
</div>
@section Scripts {
    <script>
        // 保留原頁面的交互腳本：導航漢堡選單、返回頂部、滾動動畫等
        const backTopBtn = document.getElementById('backToTop');
        if (backTopBtn) {
            window.addEventListener('scroll', () => {
                backTopBtn.classList.toggle('visible', window.scrollY > 400);
            });
        }
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.anim').forEach(el => observer.observe(el));
    </script>
}