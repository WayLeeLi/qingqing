@model Academy.ViewModels.ServiceViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";   // 使用统一的布局页（包含导航、页脚、浮动按钮）
    ViewBag.Title = "服務項目 | 青青餐廳 SINCE 1977";
}

@section Styles {
    <style>
        /* 此处放置本页面特有的 CSS，原有全局样式已移至布局页的样式文件中 */
        /* 但为确保风格一致，可以将所有 CSS 整合到 /Content/site.css 或 Bundle 中 */
        /* 以下仅保留页面专属的细微调整 */
        .svc-big-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3px;
            max-width: 1200px;
            margin: 0 auto;
        }
        /* 其他原有样式均需保留，但因篇幅略作归纳，实际使用时复制完整样式到独立 CSS 文件 */
        /* 为避免遗漏，建议将原 <style> 中除全局重置外的内容移至 /Content/service.css */
    </style>
        <link rel="stylesheet" href="~/css/service.css" />
}

<!-- ══ PAGE HERO（子页横幅）══ -->
<div class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
        <div class="tag">SERVICE</div>
        <h1>服務項目</h1>
        <div class="page-hero-breadcrumb">
            <a href="@Url.Action("Index", "Home")">首頁</a>
            &nbsp;/&nbsp;服務項目
        </div>
    </div>
    <svg class="hero-deco-line" viewBox="0 0 1440 20" preserveAspectRatio="none">
        <path d="M0,10 Q360,0 720,10 Q1080,20 1440,10 L1440,20 L0,20 Z" fill="var(--paper)" />
    </svg>
</div>

<!-- 簡介條 -->
<div class="intro-strip">
    <p>
        青青餐廳自 1977 年深耕土城，擁有千坪宴席場地、128桌容量，由台灣廚神阿發師親領廚藝團隊，
        承辦各式喜慶宴客，一手包辦婚宴、尾牙、聚餐、外帶年菜，讓每個重要時刻留下難忘滋味。
    </p>
</div>

<!-- 六大服務卡片（從 Model 動態產生） -->
<section class="section-pad" style="background:var(--paper); padding-bottom:3px;">
    <div class="svc-section-header">
        <div class="tag">服務項目</div>
        <h2 class="h2">每個重要時刻<br>交給青青</h2>
        <div class="gold-rule"><span>◆</span></div>
    </div>
</section>

<div class="svc-big-grid">
    @foreach (var service in Model.Services)
    {
        <div class="svc-big-card anim">
            <div class="card-bg" style="background-image:url('@service.ImageUrl');"></div>
            <div class="card-grad"></div>
            <div class="card-body">
                <div class="card-number">@service.SerialNumber</div>
                <span class="card-icon">@service.Icon</span>
                <div class="card-title">@service.Title</div>
                <div class="card-en">@service.SubtitleEn</div>
                <div class="card-divider"></div>
                <p class="card-desc">@service.Description</p>
                <a href="@service.ContactLink" class="card-cta">@service.CtaText →</a>
            </div>
        </div>
    }
</div>

<!-- 優勢特色區（從 Model 動態） -->
<section class="feature-section">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="tag" style="color:var(--gold); --red:var(--gold);">青青優勢</div>
        <h2 class="h2" style="color:#fff;">為何選擇青青餐廳</h2>
    </div>
    <div class="feature-grid">
        @foreach (var feature in Model.Features)
        {
            <div class="feature-item anim">
                <div class="feature-icon">@feature.Icon</div>
                <div class="feature-title">@feature.Title</div>
                <p class="feature-desc">@feature.Description</p>
            </div>
        }
    </div>
</section>

<!-- 價格方案表（從 Model 動態） -->
<section class="price-section">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="tag">參考方案</div>
        <h2 class="h2">宴席套案一覽</h2>
        <div class="gold-rule"><span>◆</span></div>
        <p style="opacity:.6; font-size:.88rem; line-height:1.9; max-width:560px;">
            以下為參考方案，實際報價依菜色選擇、桌數、場地配置而定。歡迎電話或親臨洽談，由專人為您量身規劃最適合的宴席方案。
        </p>
    </div>
    <div class="price-table-wrap anim">
        <table class="price-table">
            <thead>
                <tr>
                    <th>服務類型</th>
                    <th>適合人數</th>
                    <th>參考價位</th>
                    <th>包含內容</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var plan in Model.PricePlans)
                {
                    <tr>
                        <td>
                            <strong>@plan.TypeName</strong>
                            <div class="price-note">@plan.TypeEn</div>
                        </td>
                        <td>@plan.Audience</td>
                        <td><span class="price-badge">@plan.PriceRange</span></td>
                        <td>@plan.Inclusions</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<!-- 加值服務卡片群（從 Model 動態） -->
<section class="section-pad" style="background:var(--paper); padding-top:2rem;">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="tag">附加服務</div>
        <h2 class="h2">更多貼心選項</h2>
    </div>
    <div class="services-grid">
        @foreach (var extra in Model.ExtraServices)
        {
            <div class="service-card anim">
                <div class="svc-icon">@extra.Icon</div>
                <div class="svc-title">@extra.Title</div>
                <p class="svc-desc">@extra.Description</p>
            </div>
        }
    </div>
</section>

<!-- CTA 區塊（可保留靜態，亦可從 Model 獲取電話等） -->
<div class="cta-strip">
    <div class="cta-strip-inner">
        <h2>準備好為您服務</h2>
        <p>歡迎來電或親臨洽談，專人為您量身規劃最完美的宴席方案<br>每日 11:00 — 22:00 全年無休（特殊節日除外）</p>
        <div class="cta-btns">
            <a href="tel:@ViewBag.Phone1" class="btn-white">📞 @ViewBag.Phone1</a>
            <a href="tel:@ViewBag.Phone2" class="btn-outline-white">📞 @ViewBag.Phone2</a>
        </div>
    </div>
</div>

<!-- 聯絡資訊區（與布局中的聯繫方式可能重複，但此處保留完整內容，可根據需求隱藏布局中的區塊） -->
<div class="contact-wrap" id="contact">
    <div class="contact-info">
        <div class="tag">聯絡我們</div>
        <h2 class="h2" style="color:#fff; margin-bottom:0;">歡迎蒞臨<br>青青餐廳</h2>
        <div class="contact-items">
            <div class="c-item">
                <div class="c-icon">📍</div>
                <div>
                    <div class="c-label">地址</div>
                    <div class="c-text">
                        @ViewBag.Address<br>
                        <small style="opacity:.6">@ViewBag.TrafficInfo</small>
                    </div>
                </div>
            </div>
            <div class="c-item">
                <div class="c-icon">📞</div>
                <div>
                    <div class="c-label">訂位電話</div>
                    <div class="c-text">
                        <a href="tel:@ViewBag.Phone1">@ViewBag.Phone1</a><br>
                        <a href="tel:@ViewBag.Phone2">@ViewBag.Phone2</a>
                    </div>
                </div>
            </div>
            <div class="c-item">
                <div class="c-icon">📠</div>
                <div>
                    <div class="c-label">傳真</div>
                    <div class="c-text">@ViewBag.Fax</div>
                </div>
            </div>
            <div class="c-item">
                <div class="c-icon">🕐</div>
                <div>
                    <div class="c-label">營業時間</div>
                    <div class="c-text">@ViewBag.BusinessHours</div>
                </div>
            </div>
            <div class="c-item">
                <div class="c-icon">✉️</div>
                <div>
                    <div class="c-label">電子信箱</div>
                    <div class="c-text"><a href="mailto:@ViewBag.Email">@ViewBag.Email</a></div>
                </div>
            </div>
        </div>
    </div>
    <div class="map-box">
        <iframe src="@ViewBag.MapEmbedUrl" style="border:0;width:100%;height:100%;min-height:420px;display:block;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="青青餐廳地圖位置"></iframe>
    </div>
</div>

@section Scripts {
    <script>
        // 保留原頁面的交互腳本：導航漢堡選單、返回頂部、滾動動畫等
        // 注意：導航按鈕已移至佈局頁，此處只補齊本頁特有功能
        const backTopBtn = document.getElementById('backToTop');
        if (backTopBtn) {
            window.addEventListener('scroll', () => {
                backTopBtn.classList.toggle('visible', window.scrollY > 400);
            });
        }
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.anim').forEach(el => observer.observe(el));
    </script>
}