@section Scripts {
    <script>
        // 英雄区背景图 fallback（首页特有，可選）
        (function () {
            var bgLayer = document.querySelector('.hero-bg-layer');
            if (!bgLayer) return;
            var urls = [
                'https://images.unsplash.com/photo-1563245372-f21724e3856d?w=1800&q=90',
                'https://images.unsplash.com/photo-1455619452474-d2be8b1e70cd?w=1800&q=90',
                'https://images.unsplash.com/photo-1547592180-85f173990554?w=1800&q=90'
            ];
            var idx = 0;
            function tryLoad(url) {
                var img = new Image();
                img.onload = function () { bgLayer.style.backgroundImage = "url('" + url + "')"; };
                img.onerror = function () { if (++idx < urls.length) tryLoad(urls[idx]); };
                img.src = url;
            }
            tryLoad(urls[idx]);
        })();

        // 首页滚动动画（服务卡片等）
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.service-card, .story-img-frame, .story-grid > div:last-child').forEach(function (el) {
            el.style.opacity = '0';
            el.style.transform = 'translateY(28px)';
            el.style.transition = 'opacity .75s ease, transform .75s ease';
            observer.observe(el);
        });
    </script>
}