        <rect x="48" y="82" width="1" height="736" fill="rgba(212,168,67,0.40)" />
        <rect x="1397" y="82" width="3" height="736" fill="rgba(180,20,20,0.55)" />
        <rect x="1392" y="82" width="1" height="736" fill="rgba(212,168,67,0.40)" />
        <line x1="40" y1="82" x2="1400" y2="82" stroke="rgba(180,20,20,0.5)" stroke-width="2" />
        <line x1="40" y1="818" x2="1400" y2="818" stroke="rgba(180,20,20,0.5)" stroke-width="2" />
        <rect x="40" y="82" width="18" height="18" fill="rgba(212,168,67,0.7)" />
        <rect x="1382" y="82" width="18" height="18" fill="rgba(212,168,67,0.7)" />
        <rect x="40" y="800" width="18" height="18" fill="rgba(212,168,67,0.7)" />
        <rect x="1382" y="800" width="18" height="18" fill="rgba(212,168,67,0.7)" />
