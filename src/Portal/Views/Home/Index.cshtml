            <ellipse cx="36" cy="23" rx="22" ry="10" fill="#C8102E" stroke="#8B1A1A" stroke-width="1.5" />
            <rect x="14" y="21" width="44" height="88" rx="22" fill="#C8102E" stroke="#8B1A1A" stroke-width="1.5" />
            <line x1="25" y1="22" x2="24" y2="108" stroke="rgba(255,200,50,0.3)" stroke-width="1" />
            <line x1="36" y1="22" x2="36" y2="108" stroke="rgba(255,200,50,0.3)" stroke-width="1" />
            <line x1="47" y1="22" x2="48" y2="108" stroke="rgba(255,200,50,0.3)" stroke-width="1" />
            <ellipse cx="36" cy="109" rx="22" ry="10" fill="#C8102E" stroke="#8B1A1A" stroke-width="1.5" />
            <text x="36" y="72" text-anchor="middle" dominant-baseline="middle" font-family="serif" font-size="26" fill="#FFE566" font-weight="900">福</text>
            <line x1="28" y1="119" x2="24" y2="148" stroke="#C8102E" stroke-width="2" />
            <line x1="36" y1="119" x2="36" y2="152" stroke="#C8102E" stroke-width="2" />
            <line x1="44" y1="119" x2="48" y2="148" stroke="#C8102E" stroke-width="2" />
            <circle cx="24" cy="150" r="3" fill="#D4A843" />
            <circle cx="36" cy="154" r="3" fill="#D4A843" />
            <circle cx="48" cy="150" r="3" fill="#D4A843" />
        </g>
        <!-- 右燈籠（壽） -->
        <g transform="translate(1296,120)">
            <line x1="36" y1="0" x2="36" y2="16" stroke="#8B1A1A" stroke-width="2.5" />
            <ellipse cx="36" cy="23" rx="22" ry="10" fill="#C8102E" stroke="#8B1A1A" stroke-width="1.5" />
            <rect x="14" y="21" width="44" height="88" rx="22" fill="#C8102E" stroke="#8B1A1A" stroke-width="1.5" />
            <line x1="25" y1="22" x2="24" y2="108" stroke="rgba(255,200,50,0.3)" stroke-width="1" />
            <line x1="36" y1="22" x2="36" y2="108" stroke="rgba(255,200,50,0.3)" stroke-width="1" />
            <line x1="47" y1="22" x2="48" y2="108" stroke="rgba(255,200,50,0.3)" stroke-width="1" />
            <ellipse cx="36" cy="109" rx="22" ry="10" fill="#C8102E" stroke="#8B1A1A" stroke-width="1.5" />
            <text x="36" y="72" text-anchor="middle" dominant-baseline="middle" font-family="serif" font-size="26" fill="#FFE566" font-weight="900">壽</text>
            <line x1="28" y1="119" x2="24" y2="148" stroke="#C8102E" stroke-width="2" />
            <line x1="36" y1="119" x2="36" y2="152" stroke="#C8102E" stroke-width="2" />
            <line x1="44" y1="119" x2="48" y2="148" stroke="#C8102E" stroke-width="2" />
            <circle cx="24" cy="150" r="3" fill="#D4A843" />
            <circle cx="36" cy="154" r="3" fill="#D4A843" />
            <circle cx="48" cy="150" r="3" fill="#D4A843" />
        </g>
    </svg>

    <div class="hero-content">
        <div class="hero-logo-wrap">
            <svg class="hero-logo-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                <polygon points="100,4 158,28 192,80 192,120 158,172 100,196 42,172 8,120 8,80 42,28" fill="rgba(200,16,46,0.15)" stroke="#D4A843" stroke-width="3" />
                <polygon points="100,18 148,38 176,78 176,122 148,162 100,182 52,162 24,122 24,78 52,38" fill="none" stroke="rgba(212,168,67,0.4)" stroke-width="1.5" />
                <circle cx="100" cy="100" r="65" fill="rgba(200,16,46,0.2)" stroke="rgba(212,168,67,0.3)" stroke-width="1" />
                <text x="100" y="90" text-anchor="middle" dominant-baseline="middle" font-family="Noto Serif TC, serif" font-size="38" font-weight="900" fill="#F0CC78" letter-spacing="4">青青</text>
                <text x="100" y="130" text-anchor="middle" dominant-baseline="middle" font-family="Noto Serif TC, serif" font-size="18" font-weight="700" fill="rgba(240,204,120,0.8)" letter-spacing="6">餐廳</text>
                <circle cx="100" cy="26" r="3" fill="#D4A843" opacity=".8" />
                <circle cx="100" cy="174" r="3" fill="#D4A843" opacity=".8" />
                <circle cx="26" cy="100" r="3" fill="#D4A843" opacity=".8" />
                <circle cx="174" cy="100" r="3" fill="#D4A843" opacity=".8" />
            </svg>
            <div class="hero-since">SINCE 1977 ╱ 飲食男女廚藝顧問</div>
        </div>
        <h1 class="hero-title">青青餐廳</h1>
        <p class="hero-title-en">Chin Chin Restaurant</p>
        <p class="hero-tagline">
            台菜廚神 <em>阿發師</em> 坐鎮 ╱ 新北土城在地 <em>Since 1977</em><br>
            新台菜料理 · 千坪庭園宴廳 · 婚宴喜慶首選
        </p>
        <div class="hero-btns">
            <a href="tel:0222691127" class="btn-red">📞 電話訂位</a>
            <a href="#dishes" class="btn-outline-gold">探索菜色</a>
        </div>
    </div>

    <div class="scroll-hint">
        <div class="scroll-line"></div>
        <span>SCROLL</span>
    </div>
</section>

<!-- 關於我們 故事區域（數據綁定） -->
<section class="section-pad" id="story" style="background:var(--paper);">
    <div class="story-grid">
        @if (Model.AboutInfo != null && !string.IsNullOrEmpty(Model.AboutInfo.Content))
        {
            @Html.Raw(Model.AboutInfo.Content)
        }
        else
        {
            <p class="lead">
                1977年創立於新北土城，青青餐廳已深根在地近半個世紀。主廚施建發（阿發師）出身餐飲世家，曾擔任李安導演《飲食男女》廚藝技術顧問及手部替身，更獲頒多項國際中餐大師殊榮。
            </p>
            <br>
            <p class="lead" style="opacity:.65">
                餐廳坐擁128桌千坪宴席場地，小橋流水、瀑布庭景，氣派典雅。菜色融合傳統台菜與粵菜、川菜精華，每道佳餚皆以上選食材為本，呈現充滿創意的時尚台菜饗宴。
            </p>
        }

    </div>
</section>

<!-- 招牌料理（完全數據綁定，無 LINQ） -->
<section class="dishes-section section-pad" id="dishes">
    <div class="dishes-header">
        <div>
            <div class="tag" style="color:var(--gold); --red:var(--gold);">招牌料理</div>
            <h2 class="h2" style="color:#fff;">每一道菜<br>都是廚神之作</h2>
        </div>
        <a href="@Url.Action("Index", "Product")" class="btn-outline-gold">查看完整菜單</a>
    </div>
    <div class="dishes-grid">
        @{
            // 檢查是否有菜品資料
            bool hasDishes = Model.SignatureDishes != null && Model.SignatureDishes.Count > 0;
            if (hasDishes)
            {
                // 第一個菜品作為大卡片（tall）
                var firstDish = Model.SignatureDishes[0];
                <div class="dish-card tall">
                    <div class="dish-bg">
                        <div class="dish-bg-img" style="background-image:url('@firstDish.ImageUrl');"></div>
                        <span class="dish-icon">🍽️</span>
                    </div>
                    <div class="dish-overlay">
                        <div class="dish-tag">@firstDish.Lable</div>
                        <div class="dish-name">@firstDish.Title</div>
                        <div class="dish-desc">@firstDish.Summary</div>
                    </div>
                </div>

                // 其餘菜品（從索引 1 開始）
                for (int i = 1; i < Model.SignatureDishes.Count; i++)
                {
                    var dish = Model.SignatureDishes[i];
                    <div class="dish-card">
                        <div class="dish-bg">
                            <div class="dish-bg-img" style="background-image:url('@dish.ImageUrl');"></div>
                            <span class="dish-icon">🍽️</span>
                        </div>
                        <div class="dish-overlay">
                            <div class="dish-tag">@dish.Lable</div>
                            <div class="dish-name">@dish.Title</div>
                            <div class="dish-desc">@dish.Summary</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- 無資料時顯示佔位卡片 -->
                <div class="dish-card tall">
                    <div class="dish-bg"><div class="dish-bg-img" style="background-image:url('https://picsum.photos/id/127/400/500');"></div><span class="dish-icon">🍲</span></div>
                    <div class="dish-overlay"><div class="dish-name">敬請期待</div><div class="dish-desc">即將推出更多主廚推薦</div></div>
                </div>
            }
        }
    </div>
</section>

<!-- 紅色橫幅 引言 -->
<div class="red-banner">
    <svg class="banner-deco-line" viewBox="0 0 1440 8" preserveAspectRatio="none">
        <rect width="1440" height="8" fill="rgba(90,6,18,0.5)" />
        <path d="M0,4 Q360,0 720,4 Q1080,8 1440,4" fill="none" stroke="#D4A843" stroke-width="1" opacity=".5" />
    </svg>
    <div class="red-banner-inner">
        <p class="red-banner-quote">"名菜有歷史，好菜唯有創新"</p>
        <p class="red-banner-sub">── 台灣廚神 阿發師 施建發 ╱ 《飲食男女》幕後操刀手</p>
        <a href="tel:0222691127" class="btn-outline-gold">📞 立即訂位 0222-691-127</a>
    </div>
</div>

<!-- 最新消息（無 LINQ） -->
<section class="section-pad" id="news" style="background:var(--cream);">
    <div style="max-width:1200px;margin:0 auto;">
        <div class="tag">最新消息</div>
        <h2 class="h2">活動與公告</h2>
        <div class="news-grid">
            @{
                bool hasNews = Model.NewsList != null && Model.NewsList.Count > 0;
                if (hasNews)
                {
                    for (int i = 0; i < Model.NewsList.Count; i++)
                    {
                        var news = Model.NewsList[i];
                        <div class="news-card">
                            <div class="news-date">
                                <span class="news-month">@news.PublishDate.ToString("MMM").ToUpper()</span>
                                <span class="news-day">@news.PublishDate.Day</span>
                                <span class="news-year">@news.PublishDate.Year</span>
                            </div>
                            <div class="news-body">
                                <div class="news-tag-label">@(!string.IsNullOrEmpty(news.Category) ? news.Category : "最新消息")</div>
                                <h3 class="news-title">@news.Title</h3>
                                <p class="news-excerpt">@news.Summary</p>
                                <a href="@news.LinkUrl" class="news-more">了解更多 →</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="news-card"><div class="news-body"><p class="news-excerpt">暫無最新消息，敬請期待</p></div></div>
                }
            }
        </div>
    </div>
</section>

<!-- 影音專區（無 LINQ） -->
<section class="section-pad" id="youtube" style="background:var(--ink);">
    <div style="max-width:1200px;margin:0 auto;">
        <div class="tag" style="color:var(--gold);">影音專區</div>
        <h2 class="h2" style="color:#fff;margin-bottom:.5rem;">阿發師上菜</h2>
        <p style="color:rgba(255,255,255,.6);font-size:.9rem;margin-bottom:2.5rem;letter-spacing:.05em;">精彩料理示範 · 媒體採訪 · 廚神故事</p>
        <div class="youtube-grid">
            @{
                bool hasVideos = Model.VideoList != null && Model.VideoList.Count > 0;
                if (hasVideos)
                {
                    for (int i = 0; i < Model.VideoList.Count; i++)
                    {
                        var video = Model.VideoList[i];
                        <div class="yt-card">
                            <div class="yt-thumb">
                                @if (!string.IsNullOrEmpty(video.VideoUrl))
                                {
                                    <iframe src="@video.VideoUrl" title="@video.Title" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
                                }
                                else if (!string.IsNullOrEmpty(video.ImageUrl))
                                {
                                    <div style="position:absolute; inset:0; background-image:url('@video.ImageUrl'); background-size:cover; background-position:center;"></div>
                                }
                                else
                                {
                                    <div style="position:absolute; inset:0; background:#2a2a2a; display:flex; align-items:center; justify-content:center; color:#888;">預覽圖</div>
                                }
                            </div>
                            <div class="yt-info">
                                <div class="yt-tag">@(!string.IsNullOrEmpty(video.Category) ? video.Category : "影音分享")</div>
                                <h3 class="yt-title">@video.Title</h3>
                                <p class="yt-desc">@video.Summary</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="yt-card"><div class="yt-info"><p class="yt-desc">精采影片即將上線</p></div></div>
                }
            }
        </div>
    </div>
</section>

<!-- 服務項目（靜態） -->
<section class="section-pad" id="services" style="background:var(--paper);">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="tag">服務項目</div>
        <h2 class="h2">每個重要時刻<br>交給青青</h2>
    </div>
    <div class="services-grid">
        @{
            bool hasServices = Model.VideoList != null && Model.VideoList.Count > 0;
            if (hasServices)
            {
                for (int i = 0; i < Model.VideoList.Count; i++)
                {
                    var service = Model.VideoList[i];
                    <div class="service-card"><div class="svc-icon">@service.ImageUrl</div><div class="svc-title">@service.Title</div><p class="svc-desc">@service.Summary</p></div>

                }
            }
            else
            {
                <div class="yt-card"><div class="yt-info"><p class="yt-desc">精采影片即將上線</p></div></div>
            }
        }
    </div>
</section>

<!-- 聯絡與地圖 -->
<div class="contact-wrap" id="contact">
    <div class="contact-info">
        <div class="tag">聯絡我們</div>
        <h2 class="h2" style="color:#fff; margin-bottom:0;">歡迎蒞臨<br>青青餐廳</h2>
        <div class="contact-items">
            <!-- 地址 -->
            <div class="c-item">
                <div class="c-icon">📍</div>
                <div>
                    <div class="c-label">地址</div>
                    <div class="c-text">
                        @(string.IsNullOrEmpty(ViewBag.Address) ? "新北市土城區中央路三段6號" : ViewBag.Address)
                        <br><small style="opacity:.6">板南線永寧站4號出口，步行約350公尺</small>
                    </div>
                </div>
            </div>

            <!-- 電話（支援多組，以逗號分隔） -->
            <div class="c-item">
                <div class="c-icon">📞</div>
                <div>
                    <div class="c-label">訂位電話</div>
                    <div class="c-text">
                        @if (!string.IsNullOrEmpty(ViewBag.Phone))
                        {
                            var phones = ViewBag.Phone.ToString().Split(new[] { ',', '，', '/' }, StringSplitOptions.RemoveEmptyEntries);
                            foreach (var p in phones)
                            {
                                var cleanPhone = p.Trim().Replace(" ", "").Replace("-", "");
                                <a href="tel:@cleanPhone">@p.Trim()</a><br />
                            }
                        }
                        else
                        {
                            <a href="tel:0222691127">02-2269-1127</a><br />
                            <a href="tel:0222696430">02-2269-6430</a>
                        }
                    </div>
                </div>
            </div>

            <!-- 營業時間（支援 HTML） -->
            <div class="c-item">
                <div class="c-icon">🕐</div>
                <div>
                    <div class="c-label">營業時間</div>
                    <div class="c-text">
                        @if (!string.IsNullOrEmpty(ViewBag.BusinessHours))
                        {
                            @Html.Raw(ViewBag.BusinessHours)
                        }
                        else
                        {
                            <span>每日 11:00 — 22:00</span>
                        }
                    </div>
                </div>
            </div>

            <!-- 電子信箱 -->
            <div class="c-item">
                <div class="c-icon">✉️</div>
                <div>
                    <div class="c-label">電子信箱</div>
                    <div class="c-text">
                        @if (!string.IsNullOrEmpty(ViewBag.Email))
                        {
                            <a href="mailto:@ViewBag.Email">@ViewBag.Email</a>
                        }
                        else
                        {
                            <a href="mailto:service@chinchin.com.tw">service@chinchin.com.tw</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="map-box">
        @if (!string.IsNullOrEmpty(ViewBag.MapUrl))
        {
            <iframe src="@ViewBag.MapUrl" style="border:0;width:100%;height:100%;min-height:420px;display:block;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="青青餐廳地圖位置"></iframe>
        }
        else
        {
            <div class="alert">地圖尚未設定</div>
        }
    </div>
</div>

<!-- 浮動按鈕：LINE + 回頂部 -->
<div class="float-btns">
    <a class="float-btn float-btn-line" href="" target="_blank" rel="noopener noreferrer" data-tip="LINE 客服">
        <svg viewBox="0 0 24 24" fill="#fff" xmlns="http://www.w3.org/2000/svg">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" />
