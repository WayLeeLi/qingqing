    <div class="hero-bg-layer"></div>
    <div class="hero-overlay"></div>
    <!-- 裝飾 SVG（燈籠＋金框） -->
    <svg class="hero-svg-deco" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
