@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "青青餐廳 | 台菜廚神 SINCE 1977";
}

@section Styles {
    <link rel="stylesheet" href="~/css/index.css" />
}

<!-- Hero Banner -->
