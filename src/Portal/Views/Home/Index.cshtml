    <button class="float-btn float-btn-top" id="backToTop" data-tip="回到頂部" aria-label="回到頂部">
        <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15" />
        </svg>
    </button>
</div>

@section Scripts {
    <script>
        // 英雄區背景圖隨機載入
        (function () {
            var bgLayer = document.querySelector('.hero-bg-layer');
            if (!bgLayer) return;
            var urls = [
                '/images/web/index_bg.png',
            ];
            var idx = 0;
            function tryLoad(url) {
                var img = new Image();
                img.onload = function () { bgLayer.style.backgroundImage = "url('" + url + "')"; };
                img.onerror = function () { if (++idx < urls.length) tryLoad(urls[idx]); };
                img.src = url;
            }
            tryLoad(urls[idx]);
        })();

        // 滾動動畫：服務卡片、故事區塊
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.service-card, .story-img-frame, .story-grid > div:last-child').forEach(function (el) {
            el.style.opacity = '0';
            el.style.transform = 'translateY(28px)';
            el.style.transition = 'opacity .75s ease, transform .75s ease';
            observer.observe(el);
        });

        // 回到頂部功能
        var topBtn = document.getElementById('backToTop');
        if (topBtn) {
            window.addEventListener('scroll', function () {
                if (window.scrollY > 600) {
                    topBtn.style.opacity = '1';
                    topBtn.style.pointerEvents = 'auto';
                } else {
                    topBtn.style.opacity = '0';
                    topBtn.style.pointerEvents = 'none';
                }
            });
            topBtn.addEventListener('click', function (e) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
            topBtn.style.opacity = '0';
            topBtn.style.pointerEvents = 'none';
        }
    </script>
}