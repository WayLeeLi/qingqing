@model Academy.ViewModels.AboutViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "關於我們 - 青青餐廳";
}

@section Styles {
    <link rel="stylesheet" href="~/css/about.css" />
}

<!-- HERO 區塊（靜態保留，不做綁定） -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>
    <div class="hero-circle"></div>
    <div class="hero-content">
        <div class="hero-eye"><span>ABOUT US</span></div>
        <h1 class="hero-h1">關於<em>青青</em></h1>
        <p class="hero-sub">About Chin Chin Restaurant · Since 1977</p>
        <div class="hero-orn"><span></span><i></i><small>台灣廚神・三代傳承・土城在地</small><i></i><span></span></div>
    </div>
</section>

<!-- 錨點導航欄（靜態保留） -->
<div class="anchor-bar" id="abar">
    <div class="anchor-inner">
        <a class="anc on" href="#sec-intro"><span class="anc-dot"></span>餐廳介紹</a>
        <a class="anc" href="#sec-chef"><span class="anc-dot"></span>主廚介紹</a>
        <a class="anc" href="#sec-cred"><span class="anc-dot"></span>學歷榮耀</a>
        <a class="anc" href="#sec-philo"><span class="anc-dot"></span>廚藝哲學</a>
        <a class="anc" href="#sec-trinity"><span class="anc-dot"></span>台菜三寶</a>
        <a class="anc" href="#sec-gen"><span class="anc-dot"></span>三代傳承</a>
    </div>
</div>

@if (Model.AboutIntro != null && !string.IsNullOrEmpty(Model.AboutIntro.Content))
{
    <!-- §1 餐廳介紹 -->
    <section class="s-intro" id="sec-intro">
        <div class="wrap">
            <div class="intro-grid">
                @Html.Raw(Model.AboutIntro.Content)
            </div>
        </div>
    </section>
}

<div class="stats-band">
    <div class="wrap">
        <div class="stats-row">
            <div class="stt rv"><div class="stn">1977</div><div class="stl"><strong>創立年份</strong>FOUNDED</div></div>
            <div class="stt rv" style="transition-delay:.1s"><div class="stn">3<sup>代</sup></div><div class="stl"><strong>家族傳承</strong>GENERATIONS</div></div>
            <div class="stt rv" style="transition-delay:.2s"><div class="stn">千<sup>坪</sup></div><div class="stl"><strong>場地規模</strong>VENUE SIZE</div></div>
            <div class="stt rv" style="transition-delay:.3s"><div class="stn">44<sup>年</sup></div><div class="stl"><strong>阿發師廚齡</strong>CULINARY CAREER</div></div>
        </div>
    </div>
</div>

@if (Model.ChefIntro != null && !string.IsNullOrEmpty(Model.ChefIntro.Content))
{
    <!-- §2 主廚介紹 -->
    <section class="s-chef" id="sec-chef">
        <div class="wrap">
            <div class="chef-grid">
                @Html.Raw(Model.ChefIntro.Content)
            </div>
        </div>
    </section>
}

@if (Model.ChefCredentials != null && !string.IsNullOrEmpty(Model.ChefCredentials.Content))
{
    <!-- §3 學歷榮耀 -->
    <section class="s-cred" id="sec-cred">
        <div class="wrap">
            <div class="rv"><p class="slabel">QUALIFICATIONS</p><h2 class="stitle">學歷・證照・榮耀</h2></div>
            <div class="cred-grid">
                @Html.Raw(Model.ChefCredentials.Content)
            </div>
        </div>
    </section>
}

@if (Model.ChefPhilosophy != null && !string.IsNullOrEmpty(Model.ChefPhilosophy.Content))
{
    <!-- §4 廚藝哲學 -->
    <section class="s-philo" id="sec-philo">
        <div class="wrap">
            <div class="rv"><p class="slabel">OUR PHILOSOPHY</p><h2 class="stitle">阿發師的廚藝哲學</h2></div>
            <div class="philo-grid">
                @Html.Raw(Model.ChefPhilosophy.Content)
            </div>
        </div>
    </section>
}

@if (Model.Trinity != null && !string.IsNullOrEmpty(Model.Trinity.Content))
{
    <!-- §5 台菜三寶 -->
    <section class="s-trinity" id="sec-trinity">
        <div class="wrap">
            <div class="rv">
                <p class="slabel">FLAVOUR SECRETS</p>
                <h2 class="stitle">台菜風味三寶</h2>
                <p class="sdesc">阿發師說：「這三種組合都是絕配，是我們的廚房三寶。如果這三種油可以做到好，也就掌握了台菜的大半精髓。」</p>
            </div>
            <div class="trow rv" style="transition-delay:.14s">
                @Html.Raw(Model.Trinity.Content)
            </div>
        </div>
    </section>
}

@if (Model.FamilyHeritage != null && !string.IsNullOrEmpty(Model.FamilyHeritage.Content))
{
    <!-- §6 三代傳承 -->
    <section class="s-gen" id="sec-gen">
        <div class="wrap">
            <div class="rv"><p class="slabel">FAMILY HERITAGE</p><h2 class="stitle">三代飲食傳承</h2></div>
            <div class="timeline">
                @Html.Raw(Model.FamilyHeritage.Content)
            </div>
        </div>
    </section>
}

<!-- CTA 預約區塊（靜態保留，不做綁定） -->
<section class="booking-section">
    <div class="booking-overlay"></div>
    <div class="booking-content">
        <p class="booking-label">RESERVATION</p>
        <h2 class="booking-title">立即預訂，品嚐阿發師三代手路饗宴</h2>
        <p class="booking-address">新北市土城區中央路三段6號 ╱ 捷運板南線永寧站4號出口</p>
        <div class="booking-buttons">
            <a href="tel:0222691127" class="btn-primary">📞 (02) 2269-1127</a>
            <a href="@Url.Action("Product", "Home")" class="btn-secondary">查看菜單 →</a>
        </div>
    </div>
</section>

<button id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <svg viewBox="0 0 24 24"><path d="M12 4L4 12h5v8h6v-8h5z" /></svg>
</button>

@section Scripts {
    <script>
        // 回到頂部按鈕
        const btt = document.getElementById('btt');
        window.addEventListener('scroll', function () {
            btt.classList.toggle('vis', window.scrollY > 200);
        });

        // 滾動淡入動畫
        const observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: .1 });
        document.querySelectorAll('.rv').forEach(function (el) {
            observer.observe(el);
        });

        // 錨點導航平滑滾動 + 偏移補正
        const OFFSET = 72 + 44 + 4;
        document.querySelectorAll('.anc').forEach(function (a) {
            a.addEventListener('click', function (e) {
                e.preventDefault();
                const id = a.getAttribute('href').slice(1);
                const el = document.getElementById(id);
                if (!el) return;
                window.scrollTo({
                    top: el.getBoundingClientRect().top + window.scrollY - OFFSET,
                    behavior: 'smooth'
                });
            });
        });

        // 滾動監聽高亮當前章節（僅針對存在的區塊）
        const sections = ['sec-intro', 'sec-chef', 'sec-cred', 'sec-philo', 'sec-trinity', 'sec-gen'];
        const anchors = document.querySelectorAll('.anc');
        const spy = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    anchors.forEach(function (a) {
                        a.classList.toggle('on', a.getAttribute('href') === '#' + entry.target.id);
                    });
                    const activeAnchor = document.querySelector('.anc.on');
                    if (activeAnchor) {
                        const bar = document.querySelector('.anchor-inner');
                        bar.scrollTo({
                            left: activeAnchor.offsetLeft - bar.offsetWidth / 2 + activeAnchor.offsetWidth / 2,
                            behavior: 'smooth'
                        });
                    }
                }
            });
        }, { rootMargin: '-22% 0px -68% 0px' });
        sections.forEach(function (id) {
            const el = document.getElementById(id);
            if (el) spy.observe(el);
        });
    </script>
}