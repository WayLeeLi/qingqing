@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "聯絡我們 - 青青餐廳";
}

@section Styles {
    <link rel="stylesheet" href="~/css/contact.css" />
}

<!-- Hero 區塊 -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>
    <div class="hero-deco"></div>
    <div class="hero-content">
        <div class="hero-eye"><span>CONTACT US</span></div>
        <h1 class="hero-h1">聯絡<em>我們</em></h1>
        <p class="hero-sub">Contact · Reservation · Direction</p>
        <div class="hero-orn"><span></span><i></i><small>新北市土城區 · SINCE 1977</small><i></i><span></span></div>
    </div>
</section>

<!-- 聯絡資訊 + 地圖 -->
<section class="s-contact">
    <div class="wrap">
        <div class="contact-grid">

            <!-- 左：資訊 -->
            <div class="info-col">
                <div class="rv"><p class="slabel">GET IN TOUCH</p><h2 class="stitle">餐廳資訊</h2></div>
                <div class="info-cards rv" style="transition-delay:.1s">
                    <!-- 地址 -->
                    <div class="icard">
                        <div class="icard-ico"><svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg></div>
                        <div class="icard-body">
                            <div class="icard-label">ADDRESS 地址</div>
                            <div class="icard-val">@ViewBag.Address</div>
                            <div class="icard-note">捷運板南線　永寧站 4 號出口</div>
                        </div>
                    </div>
                    <!-- 電話與傳真 -->
                    <div class="icard">
                        <div class="icard-ico"><svg viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" /></svg></div>
                        <div class="icard-body">
                            <div class="icard-label">PHONE 電話</div>
                            <div class="icard-val">
                                @if (!string.IsNullOrEmpty(ViewBag.Phone))
                                {
                                    var phones = ViewBag.Phone.Split(new[] { ',', '，', '/' }, StringSplitOptions.RemoveEmptyEntries);
                                    foreach (var p in phones)
                                    {
                                        <a href="tel:@p.Replace(" ", "").Replace("-", "")">@p</a><text>　</text>
                                    }
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(ViewBag.Fax))
                            {
                                <div class="icard-note">傳真：@ViewBag.Fax</div>
                            }
                        </div>
                    </div>
                    <!-- 電子信箱 -->
                    <div class="icard">
                        <div class="icard-ico"><svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" /></svg></div>
                        <div class="icard-body">
                            <div class="icard-label">EMAIL 電子信箱</div>
                            <div class="icard-val"><a href="mailto:@ViewBag.Email">@ViewBag.Email</a></div>
                        </div>
                    </div>
                </div>

                <!-- 營業時間（支援 HTML） -->
                @if (!string.IsNullOrEmpty(ViewBag.BusinessHours))
                {
                    <div class="hours-card rv" style="transition-delay:.18s">
                        <div class="hours-title">OPENING HOURS 營業時間</div>
                        @Html.Raw(ViewBag.BusinessHours)
                    </div>
                }

                <!-- 社群按鈕 -->
                <div class="social-row rv" style="transition-delay:.25s">
                    <a class="soc-btn line" href="https://lin.ee/xxxxxxxx" target="_blank">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.07 9.436-6.975C23.176 14.393 24 12.458 24 10.314" /></svg>
                        LINE 官方帳號
                    </a>
                    <a class="soc-btn ig" href="https://www.instagram.com/2020tchintchin/" target="_blank">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" /></svg>
                        Instagram
                    </a>
                </div>
            </div>

            <!-- 右：地圖 -->
            <div class="map-col rv" style="transition-delay:.12s">
                <div class="map-wrap">
                    <iframe src="https://maps.google.com/maps?q=@ViewBag.MapLatitude,@ViewBag.MapLongitude&z=16&output=embed"
                            allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    <a class="map-btn" href="https://maps.google.com/maps?q=@ViewBag.MapLatitude,@ViewBag.MapLongitude" target="_blank">
                        <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                        Google Maps 開啟
                    </a>
                </div>
                <!-- 交通指引 -->
                @if (!string.IsNullOrEmpty(ViewBag.TrafficGuide))
                {
                    <div class="trans-card rv" style="transition-delay:.22s">
                        <div class="trans-title">TRANSPORTATION 交通指引</div>
                        @Html.Raw(ViewBag.TrafficGuide)
                    </div>
                }
            </div>

        </div>
    </div>
</section>

<!-- 預約表單 -->
<section class="s-form">
    <div class="wrap">
        <div class="form-layout">
            <div class="form-intro rv">
                <div><p class="slabel">RESERVATION</p><h2 class="stitle">線上預約<br>訂位詢問</h2></div>
                @if (!string.IsNullOrEmpty(ViewBag.OnlineBookingText))
                {
                    <p class="sdesc">@ViewBag.OnlineBookingText</p>
                }
                else
                {
                    <p class="sdesc">無論家庭聚餐、商務宴請、婚宴壽宴，歡迎填寫以下表單，我們將盡快與您確認訂位細節。</p>
                }
                <ul class="note-list">
                    <li>建議提前 <strong>3 天以上</strong>預約，以便安排最佳座位</li>
                    <li>10 人以上桌菜宴席，請提前 <strong>7 天</strong>洽詢</li>
                    <li>婚宴、喜宴、壽宴等包場，歡迎<strong>來電洽詢</strong>專屬方案</li>
                    <li>菜色可依需求<strong>客製化調整</strong>，歡迎提出</li>
                </ul>
                <div class="direct-cta">
                    <p>急需訂位？直接致電，即時為您服務</p>
                    <a href="tel:0222691127"><svg viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" /></svg>(02) 2269-1127</a>
                    <a href="tel:0222696430"><svg viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" /></svg>(02) 2269-6430</a>
                </div>
            </div>

            <div class="cform rv" style="transition-delay:.14s">
                <div class="fgrid">
                    <div class="fg"><label class="flbl">姓名 <span class="req">*</span></label><input class="fi" type="text" id="f-name" placeholder="請輸入您的姓名"></div>
                    <div class="fg"><label class="flbl">聯絡電話 <span class="req">*</span></label><input class="fi" type="tel" id="f-phone" placeholder="0912-345-678"></div>
                    <div class="fg"><label class="flbl">電子信箱</label><input class="fi" type="email" id="f-email" placeholder="email@example.com"></div>
                    <div class="fg"><label class="flbl">用餐日期 <span class="req">*</span></label><input class="fi" type="date" id="f-date"></div>
                    <div class="fg">
                        <label class="flbl">用餐時段 <span class="req">*</span></label>
                        <select class="fs" id="f-time"><option value="">請選擇時段</option><option>午餐　11:00 – 14:00</option><option>晚餐　17:00 – 21:00</option></select>
                    </div>
                    <div class="fg">
                        <label class="flbl">用餐人數 <span class="req">*</span></label>
                        <select class="fs" id="f-guests"><option value="">請選擇人數</option><option>2 – 4 人</option><option>5 – 9 人</option><option>10 – 19 人（桌菜）</option><option>20 人以上（包廂/宴席）</option></select>
                    </div>
                    <div class="fg ffull">
                        <label class="flbl">宴席類型</label>
                        <select class="fs" id="f-type"><option value="">請選擇類型</option><option>一般聚餐</option><option>商務宴請</option><option>婚宴 / 訂婚</option><option>壽宴 / 生日</option><option>公司尾牙 / 春酒</option><option>其他</option></select>
                    </div>
                    <div class="fg ffull"><label class="flbl">備註 / 特殊需求</label><textarea class="ft" id="f-note" placeholder="如有特殊菜色需求、過敏食材或其他安排，請在此說明…"></textarea></div>
                    <div class="ffull"><button class="fsubmit" onclick="submitForm()">送出預約訊息　→</button></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA 區塊 -->
<section class="s-cta">
    <p class="cta-label">FIND US</p>
    <h2 class="cta-title">期待在青青與您相見</h2>
    <p class="cta-address">新北市土城區中央路三段6號 ╱ 捷運板南線永寧站4號出口</p>
    <div class="cta-buttons">
        <a href="tel:0222691127" class="btn-primary">📞 (02) 2269-1127</a>
        <a href="@Url.Action("Product", "Home")" class="btn-secondary">查看菜單 →</a>
    </div>
</section>

<button id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <svg viewBox="0 0 24 24"><path d="M12 4L4 12h5v8h6v-8h5z" /></svg>
</button>

<div id="toast">
    <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg>
    訊息已送出！我們將盡快與您聯繫。
</div>

@section Scripts {
    <script>
        // 回到頂部按鈕
        const btt = document.getElementById('btt');
        window.addEventListener('scroll', function () {
            btt.classList.toggle('vis', window.scrollY > 200);
        });

        // 滾動淡入動畫
        const observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: .1 });
        document.querySelectorAll('.rv').forEach(function (el) {
            observer.observe(el);
        });

        // 設定日期選擇器最小為今天
        const dateInput = document.getElementById('f-date');
        const today = new Date();
        const pad = function (n) { return String(n).padStart(2, '0'); };
        dateInput.min = `${today.getFullYear()}-${pad(today.getMonth() + 1)}-${pad(today.getDate())}`;

        // 表單提交（AJAX）
        window.submitForm = function () {
            const name = document.getElementById('f-name').value.trim();
            const phone = document.getElementById('f-phone').value.trim();
            const email = document.getElementById('f-email').value.trim();
            const date = document.getElementById('f-date').value;
            const timeSlot = document.getElementById('f-time').value;
            const guests = document.getElementById('f-guests').value;
            const eventType = document.getElementById('f-type').value;
            const note = document.getElementById('f-note').value;

            // 必填檢查
            let isValid = true;
            const requiredIds = ['f-name', 'f-phone', 'f-date', 'f-time', 'f-guests'];
            requiredIds.forEach(function (id) {
                const el = document.getElementById(id);
                if (!el.value.trim()) {
                    el.style.borderColor = 'var(--red)';
                    setTimeout(function () { el.style.borderColor = ''; }, 2200);
                    isValid = false;
                }
            });
            if (!isValid) return;

            const btn = document.querySelector('.fsubmit');
            const originalText = btn.innerText;
            btn.innerText = '傳送中...';
            btn.disabled = true;

            fetch('@Url.Action("PostMsg", "Contact")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    name: name, phone: phone, email: email, date: date,
                    timeSlot: timeSlot, guests: guests, eventType: eventType, note: note
                })
            })
            .then(response => response.json())
            .then(data => {
                btn.innerText = originalText;
                btn.disabled = false;
                const toast = document.getElementById('toast');
                toast.innerHTML = `<svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg> ${data.message}`;
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 3500);
                if (data.success) {
                    ['f-name', 'f-phone', 'f-email', 'f-date', 'f-time', 'f-guests', 'f-type', 'f-note'].forEach(id => {
                        const el = document.getElementById(id);
                        if (el) el.value = '';
                    });
                }
            })
            .catch(() => {
                btn.innerText = originalText;
                btn.disabled = false;
                const toast = document.getElementById('toast');
                toast.innerHTML = `<svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg> 連線錯誤，請稍後再試`;
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 3500);
            });
        };
    </script>
}