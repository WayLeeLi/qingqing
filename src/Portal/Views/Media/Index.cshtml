@model Academy.ViewModels.MediaListViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "媒體報導 - 青青餐廳";
}

@section Styles {
    <link rel="stylesheet" href="~/css/media.css" />
}

<section class="hero">
    <div class="hero-bg"></div><div class="hero-gd"></div>
    <div class="hero-cnt">
        <div class="hero-eye">MEDIA COVERAGE</div>
        <h1 class="hero-h1">媒體<em>報導</em></h1>
        <p class="hero-sub">TV · Documentary · Event Records</p>
    </div>
</section>

<div class="wrap">
    <!-- 統計區塊 (靜態，可手動調整) -->
    <div class="stats-bar rv" style="margin-top:3rem;">
        <div class="stat"><div class="stat-num">30+</div><div class="stat-lbl">年媒體曝光</div></div>
        <div class="stat"><div class="stat-num">@Model.TotalCount</div><div class="stat-lbl">媒體報導數</div></div>
        <div class="stat"><div class="stat-num">1994</div><div class="stat-lbl">飲食男女 起點</div></div>
    </div>

    <div class="sec-hd rv" style="transition-delay:.1s">
        <div><p class="s-lbl">MEDIA COVERAGE</p><h2 class="s-ttl">媒體報導影音</h2></div>
        <div class="cnt-badge">共 <strong>@Model.TotalCount</strong> 支影片</div>
    </div>

    <!-- 篩選按鈕 (動態產生) -->
    <div class="filters rv" style="transition-delay:.15s">
        <button class="ftab on" onclick="ft(this,'all')">全部</button>
        @if (Model.Categories != null)
        {
            foreach (var cat in Model.Categories)
            {
                <button class="ftab" onclick="ft(this,'@cat.Tag')">@cat.Name</button>
            }
        }
    </div>

    <!-- 影片網格 -->
    <div class="vgrid" id="vgrid">
        @if (Model.MediaList != null && Model.MediaList.Any())
        {
            int delay = 0;
            foreach (var media in Model.MediaList)
            {
                <article class="vcard rv" style="transition-delay:@(delay.ToString("0.00"))s" data-tag="@media.CategoryName">
                    <div class="vthumb" onclick="openModal('@media.YouTubeId', '@media.Title.Replace("'", "\\'")')">
                        <img src="@media.ThumbnailUrl" alt="@media.Title" loading="lazy"
                             onerror="this.src='/images/media-placeholder.jpg'">
                        <div class="play-btn"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg></div>
                    </div>
                    <div class="vinfo">
                        <span class="vtag @media.TagColorClass">@media.CategoryName</span>
                        <h3 class="vtitle">@media.Title</h3>
                        @if (!string.IsNullOrEmpty(media.Source))
                        {
                            <p class="vsrc">📺 @media.Source</p>
                        }
                        <p class="vdesc">@media.Description</p>
                        <a class="vlink" href="https://www.youtube.com/watch?v=@media.YouTubeId" target="_blank" rel="noopener">在 YouTube 觀看 ↗</a>
                    </div>
                </article>
            }
        }
        else
        {
            <div class="vcard" style="text-align:center; padding: 60px 20px;">目前暫無媒體報導，請稍後再訪。</div>
        }
    </div>
</div>

<!-- CTA 區塊 -->
<section class="sec-cta">
    <p class="cta-label">RESERVATION</p>
    <h2 class="cta-title">歡迎蒞臨青青餐廳</h2>
    <p class="cta-address">新北市土城區中央路三段6號 ╱ 週一至日 11:00–14:00 ／ 17:00–21:00</p>
    <div class="cta-buttons">
        <a href="tel:0222691127" class="btn-primary">📞 立即訂位</a>
        <a href="@Url.Action("Contact", "Home")" class="btn-secondary">線上預約 →</a>
    </div>
</section>

<button id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <svg viewBox="0 0 24 24"><path d="M12 4L4 12h5v8h6v-8h5z" /></svg>
</button>

<!-- Lightbox Modal -->
<div class="modal-wrap" id="modal">
    <div class="modal-bg" onclick="closeModal()"></div>
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title" id="modalTitle"></span>
            <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <iframe id="modalFrame" src="" allowfullscreen allow="autoplay;encrypted-media"></iframe>
    </div>
</div>

@section Scripts {
    <script>
        // 回到頂部
        var btt = document.getElementById('btt');
        window.addEventListener('scroll', function () {
            btt.classList.toggle('vis', window.scrollY > 200);
        });

        // 滾動淡入動畫
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: .06 });
        document.querySelectorAll('.rv').forEach(function (el) {
            observer.observe(el);
        });

        // 分類篩選
        window.ft = function (btn, tag) {
            document.querySelectorAll('.ftab').forEach(function (t) {
                t.classList.remove('on');
            });
            btn.classList.add('on');
            document.querySelectorAll('.vcard[data-tag]').forEach(function (card) {
                var cardTag = card.getAttribute('data-tag');
                var show = (tag === 'all' || cardTag === tag);
                card.style.display = show ? 'flex' : 'none';
                if (show) {
                    setTimeout(function () { card.classList.add('in'); }, 30);
                } else {
                    card.classList.remove('in');
                }
            });
        };

        // Lightbox
        var modal = document.getElementById('modal');
        var modalFrame = document.getElementById('modalFrame');
        var modalTitle = document.getElementById('modalTitle');

        window.openModal = function (vid, title) {
            modalTitle.textContent = title;
            modalFrame.src = 'https://www.youtube.com/embed/' + vid + '?autoplay=1&rel=0';
            modal.classList.add('open');
            document.body.style.overflow = 'hidden';
        };

        window.closeModal = function () {
            modal.classList.remove('open');
            modalFrame.src = '';
            document.body.style.overflow = '';
        };

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeModal();
        });
    </script>
}