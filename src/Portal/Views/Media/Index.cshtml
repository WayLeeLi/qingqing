<button id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})"><svg viewBox="0 0 24 24"><path d="M12 4L4 12h5v8h6v-8h5z" /></svg></button>

<!-- Lightbox Modal -->
<div class="modal-wrap" id="modal">
    <div class="modal-bg" onclick="closeModal()"></div>
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title" id="modalTitle"></span>
            <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <iframe id="modalFrame" src="" allowfullscreen allow="autoplay;encrypted-media"></iframe>
    </div>
</div>

@section Scripts {
    <script>
        // 回到頂部按鈕
        var btt = document.getElementById('btt');
        window.addEventListener('scroll', function () {
            btt.classList.toggle('vis', window.scrollY > 200);
        });

        // 滾動淡入動畫
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: .06 });
        document.querySelectorAll('.rv').forEach(function (el) {
            observer.observe(el);
        });

        // 分類篩選功能
        window.ft = function (btn, tag) {
            document.querySelectorAll('.ftab').forEach(function (t) {
                t.classList.remove('on');
            });
            btn.classList.add('on');
            document.querySelectorAll('.vcard').forEach(function (card) {
                var cardTag = card.getAttribute('data-tag');
                var show = (tag === 'all' || cardTag === tag);
                card.style.display = show ? 'flex' : 'none';
                if (show) {
                    setTimeout(function () { card.classList.add('in'); }, 30);
                } else {
                    card.classList.remove('in');
                }
            });
        };

        // 影片 Modal
        var modal = document.getElementById('modal');
        var modalFrame = document.getElementById('modalFrame');
        var modalTitle = document.getElementById('modalTitle');

        window.openModal = function (vid, title) {
            modalTitle.textContent = title;
            modalFrame.src = 'https://www.youtube.com/embed/' + vid + '?autoplay=1&rel=0';
            modal.classList.add('open');
            document.body.style.overflow = 'hidden';
        };

        window.closeModal = function () {
            modal.classList.remove('open');
            modalFrame.src = '';
            document.body.style.overflow = '';
        };

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeModal();
        });
    </script>
}