@using PagedList
@using PagedList.Mvc
@model IEnumerable<Academy.Models.Member>

@{
    var ModelName = "會員專區";
    ViewBag.Title = ModelName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link href="~/Content/pager.css" rel="stylesheet" />
}
@section Scripts {
}

<div class="main">
    <div class="minner">
        <div class="row col1 row_0">
            <div class="mrow">
                <div class="col col_02">
                    <div class="mcol">
                        <div id="Dyn_2_1" class="M19461">
                            <div class="module module-um md_style1">
                                <header class="mt mthide">
                                </header>

                                <section class="mb">
                                    <div class="minner">
                                        <script src="/js/tmcata.js"></script>
                                    </div>
                                </section>
                            </div>
                        </div>
                        <div id="Dyn_2_2" class="M19465">
                            <div class="mpgdetail">
                                <div class="container-inner page memberlist">
                                    <h1 class="index-title"><span class="en">MEMBERS</span><span class="ch">@ModelName</span></h1>
                                    <div class="row">
                                        <div class="col-xs-12 table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>會員編號</th>
                                                        <th>會員名稱</th>
                                                        <th>聯絡電話</th>
                                                        <th>聯絡地址</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (Model.Count() == 0)
                                                    {
                                                        <tr>
                                                            <td colspan="5">
                                                                <h3 class="empty-text">暫無資料！</h3>
                                                            </td>
                                                        </tr>
                                                    }
                                                    @foreach (var item in Model)
                                                    {
                                                        <tr>
                                                            <td>@item.Code</td>
                                                            <td>@item.Name</td>
                                                            <td>@item.Tel</td>
                                                            <td>@item.Addr</td>
                                                            <td><a href="/member/detail?id=@item.ID"><i class="fa fa-chevron-circle-right"></i></a></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                        @{
                                            var data = Model as IPagedList<Academy.Models.Member>;
                                        }
                                        @if (data.TotalItemCount > 100)
                                        {
                                            <div class="mpgbar pagebar">
                                                <ul>
                                                    @Html.PagedListPager(data, page => Url.Action("Index", new { page = page }), new PagedListRenderOptions() { LinkToFirstPageFormat = "最前一頁", LinkToNextPageFormat = "下一頁", LinkToPreviousPageFormat = "上一頁", LinkToLastPageFormat = "最後一頁", DisplayItemSliceAndTotal = true, ItemSliceAndTotalFormat = "共有 {2} 筆", MaximumPageNumbersToDisplay = 5 })
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
