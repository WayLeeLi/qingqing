@using PagedList
@using PagedList.Mvc
@model IPagedList<Academy.Models.Category>

@{
    Layout = "~/Areas/Sysmgr/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "类别管理";

    // 从 ViewBag 获取数据
    var childCounts = ViewBag.ChildCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var currentParentId = ViewBag.CurrentParentId as int?;
    var parent = ViewBag.Parent as Academy.Models.Category;
    var parentPath = ViewBag.ParentPath as string;
}

@section Scripts {
    <script>
        $(function () {
            //刪除確認視窗
            $(".icon-trash-bin").click(function () {
                var itemId = $(this).data("id");
                var itemName = $(this).data("title");
                $("#delete-confirm").dialog({
                    position: { my: 'center', at: 'center' },
                    resizable: true,
                    height: 220,
                    modal: true,
                    open: function () {
                        $(this).find(".mark").html("ID " + itemId + ": " + itemName);
                    },
                    buttons: {
                        "確認刪除": function () {
                            $(this).dialog("close");
                            $.ajax({
                                type: "POST",
                                dataType: "json",
                                url: "/Sysmgr/Category/Delete",
                                data: { id: itemId },
                                success: function (data) {
                                    if (data.success) {
                                        alert("刪除成功！");
                                        setTimeout(function () {
                                            location.href = location.href;
                                        }, 1000);
                                    } else {
                                        alert(data.message || "刪除失敗，該類別可能有子類別");
                                    }
                                },
                                error: function () {
                                    alert("刪除失敗");
                                }
                            });
                        },
                        "取消": function () {
                            $(this).dialog("close");
                        }
                    }
                });
            });

            //更新排序
            $(".btnSort").click(function () {
                var data = [];
                var hasError = false;

                $(".sort").each(function () {
                    var val = $(this).val();
                    if (val && !/^\d+$/.test(val)) {
                        alert("排序值必須為數字");
                        hasError = true;
                        return false;
                    }

                    data.push({
                        ID: $(this).data("id"),
                        Sort: val || "0"
                    });
                });

                if (hasError || data.length == 0) return;

                $.ajax({
                    type: "POST",
                    dataType: "json",
                    url: "/Sysmgr/Category/UpdateSort",
                    data: { data: JSON.stringify(data) },
                    success: function (data) {
                        alert("排序更新成功！");
                        location.href = location.href;
                    },
                    error: function () {
                        alert("排序更新失敗");
                    }
                });
            });

            //返回上級
            $("#btnBackToParent").click(function () {
                var parentId = $(this).data("parentid");
                if (parentId) {
                    location.href = '/Sysmgr/Category/Index?parentId=' + parentId;
                } else {
                    location.href = '/Sysmgr/Category/Index';
                }
            });
        });
    </script>
}

<!--主要內容-->
<article id="content" class="contentArea">
    <section class="btnArea">
        <a href="/Sysmgr/Category/Create?parentId=@currentParentId" class="add">
            <span class="icon-plus"></span>新增類別
        </a>
        @if (currentParentId.HasValue)
        {
            <a href="javascript:;" id="btnBackToParent" data-parentid="@(parent != null ? parent.ParentId : null)" class="back">
                <span class="icon-undo"></span>返回上級
            </a>
        }
        <a href="/Sysmgr/Category/Index" class="back" style="background-color:#17a2b8;">
            <span class="icon-home"></span>頂級類別
        </a>
    </section>

    <h1>
        類別管理
        <span>/ 類別列表</span>
        @if (currentParentId.HasValue && !string.IsNullOrEmpty(parentPath))
        {
            <span class="current-path">
                目前位置：@parentPath
            </span>
        }
        <span class="tip">
            <section class="tipBox">
                <span>&nbsp;</span>
                <ul>
                    <li>下列是目前類別列表。</li>
                    <li>點擊類別名稱右側的"查看子類別"可進入該類別的下層管理。</li>
                    <li>排序數字越小，顯示越靠前。</li>
                </ul>
            </section>
        </span>
    </h1>

    <section class="selectArea">
        <div class="selectMenu" style="width:250px;">
            <p>關鍵字搜尋 :</p>
            <input type="text" id="txtKeyword" value="@ViewBag.Keyword" placeholder="請輸入類別名稱" />
        </div>
        <input type="button" value="送出" onclick="location.href = '/Sysmgr/Category/Index?parentId=@currentParentId&keyword=' + encodeURIComponent($('#txtKeyword').val())">
        <input type="button" value="重設" onclick="location.href = '/Sysmgr/Category/Index?parentId=@currentParentId'">
    </section>

    <section class="tableArea">
        <table border="0" class="responsive" cellpadding="0" cellspacing="0">
            <thead>
                <tr class="titlebar">
                    <td class="alignLeft main" style="width:45%;">類別名稱</td>
                    <td class="minWidth" style="width:10%;">層級</td>
                    <td class="minWidth" style="width:10%;">排序</td>
                    <td class="time minWidth" style="width:20%;">建立時間</td>
                    <td class="btn minWidth" style="width:15%;">功能</td>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" align="center" style="padding:30px;">暫無資料！</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    var childCount = childCounts.ContainsKey(item.Id) ? childCounts[item.Id] : 0;
                    <tr>
                        <td class="alignLeft">
                            @* 根據層級縮進 *@
                            @for (int i = 0; i < item.Level; i++)
                            {
                                <span style="display:inline-block; width:25px;"></span>
                            }
                            @if (item.Level > 0)
                            {
                                <span style="color:#999; margin-right:5px;">└</span>
                            }
                            <strong>@item.Name</strong>
                            @if (childCount > 0)
                            {
                                <a href="/Sysmgr/Category/Index?parentId=@item.Id" style="margin-left:15px; color:#0066cc; text-decoration:none; font-size:12px; background:#f0f0f0; padding:2px 8px; border-radius:3px;">
                                    查看子類別 (@childCount)
                                </a>
                            }
                        </td>
                        <td>@(item.Level + 1) 級</td>
                        <td>
                            <input type="text" class="sort" data-id="@item.Id" value="@item.SortOrder" style="width:50px; text-align:center; border:1px solid #ddd; padding:3px; border-radius:3px;" />
                        </td>
                        <td class="num">@item.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <p class="function" style="margin:0; white-space:nowrap;">
                                <a href="/Sysmgr/Category/Create?parentId=@item.Id" style="text-decoration:none; margin:0 5px; color:#28a745;" title="新增子類別">➕</a>
                                <a href="/Sysmgr/Category/Edit/@item.Id" style="text-decoration:none; margin:0 5px; color:#ffc107;" title="編輯">✏️</a>
                                <a href="javascript:;" data-id="@item.Id" data-title="@item.Name" class="icon-trash-bin" style="text-decoration:none; margin:0 5px; color:#dc3545;" title="刪除">🗑️</a>
                            </p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="numberArea">
        <p>
            共 : @Model.PageCount 頁 / 總共 : @Model.TotalItemCount 筆記錄
        </p>
        <ul>
            @Html.PagedListPager(Model,
                page => Url.Action("Index", new
                     {
                    page = page,
                    parentId = currentParentId,
                    keyword = ViewBag.Keyword
                }),
                new PagedListRenderOptions
                {
                    LinkToFirstPageFormat = "首頁",
                    LinkToNextPageFormat = "下一頁",
                    LinkToPreviousPageFormat = "上一頁",
                    LinkToLastPageFormat = "末頁",
                    MaximumPageNumbersToDisplay = 5
                }
            )
        </ul>
    </section>

    <!--功能操作-->
    <section class="openArea"><span title="開啟執行列" class="open">開啟執行列</span></section>
    <section class="functionArea">
        <span title="關閉執行列" class="close">關閉執行列</span>
        <div>
            <p>更新排序</p>
            <input type="button" value="k" class="btnSort">
        </div>
    </section>
</article>

<!-- 刪除確認對話框 -->
<div id="delete-confirm" title="確認刪除" style="display:none;">
    <p>您確定要刪除以下項目嗎？</p>
    <p class="mark" style="color:red; font-weight:bold;"></p>
    <p>此操作無法復原！</p>
</div>

<style>
    .current-path {
        font-size: 14px;
        color: #666;
        margin-left: 15px;
        font-weight: normal;
    }

    .back {
        background-color: #6c757d;
        color: white;
        padding: 8px 15px;
        border-radius: 4px;
        text-decoration: none;
        margin-left: 10px;
    }

        .back:hover {
            background-color: #5a6268;
            color: white;
            text-decoration: none;
        }

    .function a:hover {
        opacity: 0.7;
    }

    .tableArea table td.alignLeft {
        text-align: left;
        padding-left: 10px;
    }
</style>