<!DOCTYPE html>
<html>
<head>
    <!--mata資訊-->
    <meta charset="utf-8">
    <meta name="author" content="www.twevcoinclub.com" />
    <meta name="viewport" content="width=device-width initial-scale=1.0 maximum-scale=1.0 user-scalable=yes" />
    <title>智匯創新股份有限公司 網站管理系統</title>
    <!--[if lt IE 9]>
    <script src="~/Scripts/html5.js"></script>
    <![endif]-->
    <!--CSS設定呼叫區塊 Start ; 請拆出為共用呼叫檔-->
    <!--[responsive-tables] (lib)-->
    <link rel="stylesheet" href="~/Scripts/admin/responsiveTables/responsive-tables.css">
    <!--jquery-UI-->
    <link rel="stylesheet" href="~/Scripts/admin/jquery-ui/jquery-ui.css">
    <!--jquery-UI timepicker-->
    <link rel="stylesheet" href="~/Scripts/admin/jquery-ui/jquery-ui-timepicker-addon.css">
    <!-- form check-->
    <link rel="stylesheet" href="~/Scripts/admin/validation/validationEngine.jquery.css">

    <link href="~/Content/admin/styles.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/admin/reset.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/admin/share.css" rel="stylesheet" type="text/css" />
    @RenderSection("styles", required: false)

    <!--JS呼叫区块 Start ; 请拆出为共用呼叫档-->
    <!-- Source [jquery] (lib)-->
    <script type="text/javascript" src="~/Scripts/admin/jquery-2.1.0.min.js"></script>
    <!-- Source [layer] (lib)-->
    <script type="text/javascript" src="~/Scripts/layer/layer.js"></script>
    <!-- Source [jquery.form] (lib)-->
    <script type="text/javascript" src="~/Scripts/jquery.form.js"></script>
    <!-- Source [treeview] (lib)-->
    <script type="text/javascript" src="~/Scripts/admin/jquery.treeview.js"></script>
    <script type="text/javascript" src="~/Scripts/admin/jquery.cookie.js"></script>
    <!--[responsive-tables] (lib)-->
    <script type="text/javascript" src="~/Scripts/admin/responsiveTables/responsive-tables.js"></script>
    <!--jquery-UI-->
    <script type="text/javascript" src="~/Scripts/admin/jquery-ui/jquery-ui.js"></script>
    <!--jquery-UI timepicker-->
    <script type="text/javascript" src="~/Scripts/admin/jquery-ui/jquery-ui-timepicker-addon.js"></script>
    <!-- form check-->
    <script type="text/javascript" src="~/Scripts/admin/validation/languages/jquery.validationEngine-zh_TW.js"></script>
    <script type="text/javascript" src="~/Scripts/admin/validation/jquery.validationEngine.js" charset="utf-8"></script>
    <!-- Code-->
    <script type="text/javascript" src="~/Scripts/admin/share.js?v=201909"></script>

    <script type="text/javascript">
        window.custom_location = window.location.href + "?menu=@Session["menu"]&sub=@Session["sub"]";
        $(function () {
            var errors = $(".validation-summary-errors");
            if (errors.length > 0) {
                errors.delay(3000).slideUp();
            }
        });
    </script>

    @RenderSection("scripts", required: false)
</head>

<body>
    <div id="page">
        <!--確定刪除視窗 Start-->
        <div id="delete-confirm" title="提示視窗" class="hidden">
            <span class="ui-icon ui-icon-alert"></span>您確定要刪除該資料嗎？<br />
            <p><mark class="mark"></mark></p>
        </div>
        <!--確定刪除視窗 End-->
        <!--確定刪ALL除視窗 Start-->
        <div id="deleteall-confirm" title="提示視窗" class="hidden">
            <span class="ui-icon ui-icon-alert"></span>您確定要刪除符合本次搜尋之資料？<br />
        </div>
        <!--確定刪ALL除視窗 End-->
        <!--複製類型視窗 Start-->
        <div id="copy-confirm" title="提示視窗" class="hidden">
            <span class="ui-icon ui-icon-alert"></span>您確定要複製該內容？<br />
            <p><mark class="mark">內容</mark></p>
        </div>
        <!--警告視窗 For圖片判斷 Start , 請拆出為呼叫檔-->
        <a href="#" class="errorBox"></a>
        <div id="error-confirm" title="提示視窗" class="hidden">
            <span class="ui-icon ui-icon-alert"></span><span>上傳的圖檔不符合規定</span><br>
            <br>
            <p>
                目前圖檔:
                <mark class="mark"></mark>
            </p>
            <p>
                ---------------------------------------------------------------<br>
                <span class="uploadNote"></span>
            </p>
        </div>
        <!--複製類型視窗 End-->
        <!--上方選單區塊-->
        <!--上方選單區塊請拆出可單獨維護檔-->
        <header id="header" class="header">
            @*<a id="sideMenu" href="#menu">
                <img src="../../images/admin/logo.png" alt="智匯創新股份有限公司 網站管理系統" title="智匯創新股份有限公司 網站管理系統">
            </a>*@
            <h2>&nbsp; 智匯創新股份有限公司網站後台管理系統</h2>
            <!--上方選單 電腦版-->
            <ul class="topMenu">
                <p>Welcome!</p>
                <li class="icon-user">
                    <a href="/Sysmgr/Account/MyInfo">
                        @if (ViewBag.LoginUser != null)
                        {
                            var userName = ((Academy.Models.User)ViewBag.LoginUser).Name;
                            @userName
                        }
                    </a>
                </li>
                @if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1))
                {
                    <li class="icon-setting"><a href="/Sysmgr/Account">帳號管理</a></li>
                }
                <li class="icon-home-2"><a href="/Sysmgr/Main">首頁</a></li>
                <li class="icon-power"><a href="/Sysmgr/Account/Logout">登出</a> </li>
            </ul>
        </header>
        <!--上方選單 手機版時-->
        <ul class="topMenu_phone">
            <li class="icon-user"><a href="/Sysmgr/Account/MyInfo">&nbsp;</a></li>
            @if (ViewBag.LoginUser != null && (ViewBag.LoginUser.IsSuper == 1))
            {
                <li class="icon-setting"><a href="/Sysmgr/Account">&nbsp;</a></li>
            }
            <li class="icon-home-2"><a href="/Sysmgr/Main">&nbsp;</a></li>
            <li class="icon-power"><a href="/Sysmgr/Account/Logout">&nbsp;</a> </li>
        </ul>
        <!--上方選單區塊 結束-->
        <!--內容-->
        @RenderBody()

