                        <span class="icon-files">公司簡介</span>
                        <ul>
                            <li><a href="/Sysmgr/about/info?menu=2&amp;sub=1">關於智匯創新</a></li>
                            <li><a href="/Sysmgr/about/chairman?menu=2&amp;sub=2">公司使命</a></li>
                            <li><a href="/Sysmgr/about/member?menu=2&amp;sub=3">核心價值</a></li>
                        </ul>
                    </li>
                }
                @if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1 || ((Academy.Models.User)ViewBag.LoginUser).Auths.Contains("300")))
                {
                    <li class="mainLink">
                        <span class="icon-newspaper">設計服務</span>
                        <ul>
                            <li><a href="/Sysmgr/News?menu=3&amp;sub=1">內容管理</a></li>
                            <li><a href="/Sysmgr/Category?menu=3&amp;sub=2">類別管理</a></li>
                            @*<li><a href="/Sysmgr/News/Search?menu=3&amp;sub=3">搜尋及編輯</a></li>*@
                        </ul>
                    </li>
                }
                @if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1 || ((Academy.Models.User)ViewBag.LoginUser).Auths.Contains("400")))
                {
                    <li class="mainLink">
                        <span class="icon-newspaper">作品集</span>
                        <ul>
                            <li><a href="/Sysmgr/News?menu=4&amp;sub=1">內容管理</a></li>
                            <li><a href="/Sysmgr/Category?menu=4&amp;sub=2">類別管理</a></li>
                            @*<li><a href="/Sysmgr/News/Search?menu=4&amp;sub=3">搜尋及編輯</a></li>*@
                        </ul>
                    </li>
