                        <span class="icon-newspaper">新聞活動</span>
                        <ul>
                            <li><a href="/Sysmgr/News?menu=5&amp;sub=1">內容管理</a></li>
                            <li><a href="/Sysmgr/Category?menu=5&amp;sub=2">類別管理</a></li>
                            @*<li><a href="/Sysmgr/News/Search?menu=5&amp;sub=3">搜尋及編輯</a></li>*@
                        </ul>
                    </li>
                }
                @*@if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1 || ((Academy.Models.User)ViewBag.LoginUser).Auths.Contains("400")))
        {
            <li class="mainLink">
                <span class="icon-mail-1">會員名錄</span>
                <ul>
                    <li><a href="/Sysmgr/Member?menu=4&amp;sub=1">會員專區</a></li>
                    <li><a href="/Sysmgr/Member/JoinIn?menu=4&amp;sub=2">申請入會</a></li>
                </ul>
            </li>
        }*@
                @if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1 || ((Academy.Models.User)ViewBag.LoginUser).Auths.Contains("600")))
                {
                    <li class="mainLink">
                        <span class="icon-files">聯絡我們</span>
                        <ul>
                            <li><a href="/Sysmgr/Setting/Contact?menu=6&amp;sub=2">聯絡我們</a></li>
                        </ul>
                    </li>
                }
                @if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1 || ((Academy.Models.User)ViewBag.LoginUser).Auths.Contains("600")))
        {
            <li class="mainLink">
                <span class="icon-mail-1">其他訊息</span>
                <ul>
                    <li><a href="/Sysmgr/Message?menu=7&amp;sub=1">線上 Q&A</a></li>
                    <li><a href="/Sysmgr/Quote?menu=7&amp;sub=2">產品資訊</a></li>
                    <li><a href="/Sysmgr/NoteBook?menu=7&amp;sub=3">留言管理</a></li>
                    <li><a href="/Sysmgr/QuickQuote?menu=7&amp;sub=4">快速報價</a></li>
                    @*<li><a href="/Sysmgr/Setting/Mail?menu=5&amp;sub=2">系統信件設定</a></li>*@
                </ul>
            </li>
        }
                @*@if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1 || ((Academy.Models.User)ViewBag.LoginUser).Auths.Contains("600")))
                {
                    <li class="mainLink">
                        <span class="icon-files">其他訊息</span>
                        <ul>
                            <li><a href="/Sysmgr/Setting/Link?menu=6&amp;sub=1">相關連結</a></li>
                            <li><a href="/Sysmgr/Setting/Contact?menu=6&amp;sub=2">聯絡我們</a></li>
                            <li><a href="/Sysmgr/Setting/Download?menu=6&amp;sub=3">檔案下載</a></li>
                        </ul>
                    </li>
                }*@
            </ul>
            <!--版權列-->
            <div class="inside_footer">
                <footer class="footer">&copy; @DateTime.Now.Year 智匯創新股份有限公司</footer>
            </div>
        </nav>
        <!--側邊選單結束-->
    </div>
</body>
