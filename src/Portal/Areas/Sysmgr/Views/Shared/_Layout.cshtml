        <nav class="sideMenu" id="menu">
            <ul class="list">
                @if (ViewBag.LoginUser != null && (((Academy.Models.User)ViewBag.LoginUser).IsSuper == 1 || ((Academy.Models.User)ViewBag.LoginUser).Auths.Contains("100")))
                {
                    <li class="mainLink">
                        <span class="icon-home-1">首頁管理</span>
                        <ul>
                            <li><a href="/Sysmgr/Banner?menu=1&amp;sub=1">輪播圖管理</a></li>
