@{
    ViewBag.Title = "Contact Us｜G-Wise Design";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="/css/contact.css" rel="stylesheet" />
}

@section Scripts {
    <script src="/js/contact.js"></script>
}

<div class="page-hero">
    <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80');"></div>
    <div class="page-hero-grad"></div>
    <div class="page-hero-content">
        <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-label">Contact Us</span></div>
        <h1 class="page-title">Contact<br>Us</h1>
    </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a href="@Url.Action("Index", "Home")">Home</a><span>›</span>
    <span style="color:#fff">Contact Us</span>
</div>

<div class="contact-wrap">
    <div class="contact-left">
        @if (Model != null)
        {@Html.Raw(Model.Value)}
    </div>

    <div class="contact-right">
        <div class="form-label">Get In Touch</div>
        <h2 class="form-section-title">Send Us a<br>Message</h2>

        <!-- 添加 data-submit-url 属性 -->
        <form id="contactForm" method="post" data-submit-url="@Url.Action("PostMsg", "Contact")">
            <div class="form-row">
                <div class="form-group">
                    <label>Full Name <span>*</span></label>
                    <input class="form-input" name="UserName" type="text" placeholder="Your full name" required>
                </div>
                <div class="form-group">
                    <label>Company Name</label>
                    <input class="form-input" name="CompanyName" type="text" placeholder="Company or brand name">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Phone <span>*</span></label>
                    <input class="form-input" name="Tel" type="tel" placeholder="Contact phone number" required>
                </div>
                <div class="form-group">
                    <label>Email <span>*</span></label>
                    <input class="form-input" name="Mail" type="email" placeholder="your@email.com" required>
                </div>
            </div>

            <div class="form-group">
                <label>Service Interested In</label>
                <select class="form-select form-input" name="CategoryName">
                    <option value="" disabled selected>Please select a service</option>
                    @if (ViewBag.CategoryList != null)
                    {
                        var categories = ViewBag.CategoryList as List<Academy.Models.Category> ?? new List<Academy.Models.Category>();
                        foreach (var cat in categories)
                        {
                            <option value="@cat.Name">@cat.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Message <span>*</span></label>
                <textarea class="form-textarea" name="Content" placeholder="Please describe your design needs or questions..." required></textarea>
            </div>

            <button type="submit" class="form-submit">Send Message</button>
            <p class="form-note">* Required fields. We will get back to you within 1–2 business days.<br>You can also email us directly: <a href="mailto:service@g-wise.com" style="color:var(--green)">service@g-wise.com</a></p>
        </form>

        <div class="form-success" id="formSuccess" style="display:none;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6DB82A" stroke-width="2" style="margin-bottom:10px;"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
            <p>Your message has been sent successfully! We will contact you shortly. Thank you for reaching out.</p>
        </div>
    </div>
</div>