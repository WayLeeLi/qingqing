@model Academy.Models.News
@{
    ViewBag.Title = Model.Title + "｜G-Wise Design";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="/css/news-detail.css" rel="stylesheet" />
}

@section Scripts {
    <script src="/js/news-detail.js"></script>
    <script>
        // 将服务器端数据传递给 JS
        window.newsData = {
            currentId: @Model.ID,
            prevId: @(ViewBag.PrevNews != null ? ViewBag.PrevNews.ID : 0),
            nextId: @(ViewBag.NextNews != null ? ViewBag.NextNews.ID : 0)
        }
    </script>
}

<!-- HERO -->
<div class="page-hero" id="pageHero">
    <div class="hero-bg" id="heroBg" style="background-image:url('@(Model.ImagePath ?? Model.ImagePath)')"></div>
    <div class="hero-grad"></div>
    <div class="hero-content">
        <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-label">@(Model.Title ?? "News")</span></div>
        <div class="hero-date">@(Model.CDate)</div>
    </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a href="@Url.Action("Index", "Home")">Home</a>
    <span>›</span>
    <a href="@Url.Action("Index", "News")">News & Events</a>
    <span>›</span>
    <span style="color:#fff">@ViewBag.CategoryName</span>
</div>

<!-- BODY -->
<div class="detail-body">

    <!-- ARTICLE -->
    <div class="article-wrap">
        <div class="article-tag">@(Model.Title ?? "News")</div>
        <h1 class="article-title">@Model.Title</h1>
        <img class="article-img" src="@(Model.ImagePath ?? Model.ImagePath)" alt="@Model.Title">
        <div class="article-body">
            @Html.Raw(Model.Content)
        </div>

        <!-- PAGER -->
        <div class="article-pager">
            @if (ViewBag.PrevNews != null)
            {
                <a href="@Url.Action("Detail", "News", new { id = ViewBag.PrevNews.ID })" class="pager-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7" /></svg>
                    Previous
                </a>
            }
            else
            {
                <button class="pager-btn disabled" disabled>Previous</button>
            }

            <a href="@Url.Action("Index", "News")" class="pager-back">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                Back to News List
            </a>

            @if (ViewBag.NextNews != null)
            {
                <a href="@Url.Action("Detail", "News", new { id = ViewBag.NextNews.ID })" class="pager-btn">
                    Next
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                </a>
            }
            else
            {
                <button class="pager-btn disabled" disabled>Next</button>
            }
        </div>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-section">
            <div class="sidebar-section-title">@ViewBag.CategoryName</div>
            @using Academy.ViewModels
            @{
                var sidebarList = ViewBag.SidebarNewsList as List<SidebarNewsItem> ?? new List<SidebarNewsItem>();
            }
            <div class="news-list">
                @foreach (var item in sidebarList)
                {
                    <div class="news-list-item @(item.ID == Model.ID ? "active" : "")" onclick="location.href='@Url.Action("Detail", "News", new { id = item.ID })'">
                        <img class="news-list-thumb" src="@item.Thumb" alt="@item.Title">
                        <div class="news-list-info">
                            <div class="news-list-date">@item.Date</div>
                            <div class="news-list-excerpt">@item.Summary</div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="contact-card">
            <h4>G-Wise Design</h4>
            <p>3F-2, No.9, Jingguo Rd.<br>Taoyuan Dist., Taoyuan City 330, Taiwan</p>
            <p>TEL：<a href="tel:033582500">03-358-2500</a></p>
            <p>FAX：03-358-2503</p>
            <p><a href="mailto:service@g-wise.com">service@g-wise.com</a></p>
            <a href="@Url.Action("Index", "Contact")" class="contact-btn">Contact Us →</a>
        </div>
    </div>
</div>

<!-- CTA BAR（已在 Layout 中，可省略） -->