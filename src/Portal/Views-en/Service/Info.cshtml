@{
    ViewBag.Title = "Design Services｜G-Wise Design";
}

@section Styles {
    <link href="~/css/service.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/js/service.js"></script>
    <script>
        // 加载服务内容
        function loadServiceContent(categoryId, categoryName) {
            // 更新面包屑
            $('#bcCurrent').text(categoryName);

            // 更新侧边栏高亮
            $('.sidebar-sub a').removeClass('active');
            $('.sidebar-sub a').each(function () {
                if ($(this).data('cat-id') == categoryId) {
                    $(this).addClass('active');
                }
            });

            // 显示加载中
            $('#serviceContent').html('<div style="text-align:center;padding:100px;"><div class="loading-spinner"></div><p>Loading...</p></div>');

            // AJAX 请求获取服务内容
            $.ajax({
                url: '@Url.Action("GetServiceContent", "Service")',
                type: 'POST',
                data: { categoryId: categoryId },
                dataType: 'json',
                success: function (response) {
                    if (response.success) {
                        renderServiceContent(response.data);
                        // 手机版自动滚动到内容区
                        if ($(window).width() <= 768) {
                            $('html, body').animate({
                                scrollTop: $('#serviceContent').offset().top - 80
                            }, 300);
                        }
                    } else {
                        $('#serviceContent').html('<div style="text-align:center;padding:100px;color:red;">Failed to load: ' + response.message + '</div>');
                    }
                },
                error: function () {
                    $('#serviceContent').html('<div style="text-align:center;padding:100px;color:red;">Failed to load, please try again later!</div>');
                }
            });
        }

        function renderServiceContent(data) {
            var html = '';
            html += '<h1>' + escapeHtml(data.title) + '</h1>';
            html += '<div class="content-en">' + escapeHtml(data.enTitle) + '</div>';

            if (data.modules && data.modules.length > 0) {
                for (var i = 0; i < data.modules.length; i++) {
                    var module = data.modules[i];
                    html += '<div class="svc-block">';
                    html += '<h3>' + escapeHtml(module.title) + '</h3>';
                    if (module.enTitle) {
                        html += '<div class="svc-en">' + escapeHtml(module.enTitle) + '</div>';
                    }
                    if (module.images && module.images.length > 0) {
                        var colsClass = module.images.length == 1 ? 'cols-1' : 'cols-2';
                        html += '<div class="svc-imgs ' + colsClass + '">';
                        for (var j = 0; j < module.images.length; j++) {
                            html += '<img src="' + escapeHtml(module.images[j]) + '" alt="' + escapeHtml(module.title) + '">';
                        }
                        html += '</div>';
                    }
                    if (module.content) {
                        html += '<div class="svc-content">' + module.content + '</div>';
                    }
                    html += '</div>';
                }
            }

            // 分页导航
            if (data.prevCategoryId) {
                html += '<div class="page-pager">';
                html += '<a href="#" class="pager-btn" onclick="loadServiceContent(' + data.prevCategoryId + ', \'' + escapeHtml(data.prevCategoryName) + '\');return false;">← ' + escapeHtml(data.prevCategoryName) + '</a>';
                if (data.nextCategoryId) {
                    html += '<a href="#" class="pager-btn" onclick="loadServiceContent(' + data.nextCategoryId + ', \'' + escapeHtml(data.nextCategoryName) + '\');return false;">' + escapeHtml(data.nextCategoryName) + ' →</a>';
                } else {
                    html += '<span></span>';
                }
                html += '</div>';
            } else if (data.nextCategoryId) {
                html += '<div class="page-pager">';
                html += '<span></span>';
                html += '<a href="#" class="pager-btn" onclick="loadServiceContent(' + data.nextCategoryId + ', \'' + escapeHtml(data.nextCategoryName) + '\');return false;">' + escapeHtml(data.nextCategoryName) + ' →</a>';
                html += '</div>';
            }

            $('#serviceContent').html(html);
        }

        // escapeHtml 只用于转义普通文本，不要用于 content
        function escapeHtml(str) {
            if (!str) return '';
            return String(str).replace(/[&<>]/g, function (m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // 解析 URL 参数
        function getUrlParameter(name) {
            name = name.replace(/[\[]/, '\\[').replace(/[\]]/, '\\]');
            var regex = new RegExp('[\\?&]' + name + '=([^&#]*)');
            var results = regex.exec(location.search);
            return results === null ? '' : decodeURIComponent(results[1].replace(/\+/g, ' '));
        }

        // 初始化 - 根据 cataId 或默认加载第一个二级菜单
        $(function () {
            var cataId = getUrlParameter('cataId');
            if (cataId !== '') {
                var targetLink = $('.sidebar-sub a[data-cat-id="' + cataId + '"]');
                if (targetLink.length > 0) {
                    var categoryId = targetLink.data('cat-id');
                    var categoryName = targetLink.text();
                    // 展开父级菜单
                    targetLink.closest('.sidebar-cat').addClass('open');
                    loadServiceContent(categoryId, categoryName);
                    return;
                }
            }
            // 默认加载第一个二级菜单
            var firstSubMenu = $('.sidebar-sub a').first();
            if (firstSubMenu.length > 0) {
                var categoryId = firstSubMenu.data('cat-id');
                var categoryName = firstSubMenu.text();
                loadServiceContent(categoryId, categoryName);
            }
        });
    </script>
    <style>
        /* 样式保持不变 */
        .svc-content {
            font-size: 15px;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.8;
        }

            .svc-content img {
                max-width: 100%;
                height: auto;
                margin: 20px 0;
                border-radius: 8px;
            }

            .svc-content p {
                margin-bottom: 16px;
            }

            .svc-content strong,
            .svc-content em {
                color: var(--green);
            }

        .loading-spinner {
            width: 40px;
            height: 40px;
            margin: 0 auto 20px;
            border: 3px solid rgba(109, 184, 42, 0.3);
            border-top-color: var(--green);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
}

<!-- HERO -->
<div class="page-hero" id="pageHero">
    <div class="page-hero-bg" id="heroBg" style="background-image:url('https://images.unsplash.com/photo-1580274455191-1c62238fa333?w=1600&q=80')"></div>
    <div class="page-hero-gradient"></div>
    <div class="page-hero-content">
        <div class="page-hero-eyebrow">
            <div class="page-hero-line"></div>
            <span class="page-hero-label">Design Services</span>
        </div>
        <h1 class="page-hero-title">Design<br>Services</h1>
    </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb" id="breadcrumb">
    <a href="@Url.Action("Index", "Home")">Home</a>
    <span>›</span>
    <span style="color:rgba(255,255,255,0.6)">Design Services</span>
    <span>›</span>
    <span id="bcCurrent" style="color:#fff">Loading...</span>
</div>

<!-- BODY -->
<div class="page-body">
    <!-- SIDEBAR -->
    <div class="sidebar">
        @{
            var categories = ViewBag.CategoryList as List<Academy.Models.Category> ?? new List<Academy.Models.Category>();
            // 获取一级菜单（ParentId 为 null）
            var parentCategories = categories.Where(c => c.ParentId == null).OrderBy(c => c.SortOrder).ToList();
        }

        @foreach (var parent in parentCategories)
        {
            // 获取当前一级菜单下的子菜单（Status == 1 表示上线的）
            var childCategories = categories.Where(c => c.ParentId == parent.Id && c.Status == 1).OrderBy(c => c.SortOrder).ToList();

            <div class="sidebar-cat @(childCategories.Any() ? "open" : "")" id="cat_@parent.Id">
                <div class="sidebar-cat-title" onclick="toggleCat('cat_@parent.Id')">
                    @parent.Name
                    @if (childCategories.Any())
                    {
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 18l6-6-6-6" />
                        </svg>
                    }
                </div>
                @if (childCategories.Any())
                {
                    <div class="sidebar-sub">
                        @foreach (var child in childCategories)
                        {
                            <a href="#" data-cat-id="@child.Id" onclick="loadServiceContent(@child.Id, '@child.Name');return false;">@child.Name</a>
                        }
                    </div>
                }
            </div>
            <div class="sidebar-divider"></div>
        }

        <!-- 联络我们卡片 -->
        <div class="sidebar-contact">
            <h5>Contact Us</h5>
            <p>
                3F-2, No.9, Jingguo Rd., Taoyuan Dist., Taoyuan City 330, Taiwan<br>
                TEL：(03)358-2500<br>
                <a href="mailto:service@g-wise.com">service@g-wise.com</a>
            </p>
        </div>
    </div>

    <!-- CONTENT - 动态加载区域 -->
    <div class="content-area" id="serviceContent">
        <div style="text-align:center;padding:100px;">
            <div class="loading-spinner"></div>
            <p>Loading...</p>
        </div>
    </div>
</div>